@import "./utils/iconfont.wxss";

/* ===== Vant 主题变量覆盖 ===== */
page {
  /* 品牌色 */
  --primary-color: #4A90D9;
  --success-color: #4CAF50;
  --warning-color: #FF9800;
  --danger-color: #f44336;

  /* Vant 组件变量 */
  --button-primary-background-color: var(--primary-color);
  --button-primary-border-color: var(--primary-color);
  --button-border-radius: 16rpx;
  --button-round-border-radius: 999rpx;
  --button-default-height: 80rpx;
  --button-large-height: 88rpx;
  --tag-primary-color: var(--primary-color);
  --tab-active-text-color: var(--primary-color);
  --tabs-bottom-bar-color: var(--primary-color);
  --nav-bar-background-color: #fff;
  --dialog-confirm-button-text-color: var(--primary-color);
  --cell-border-color: #f5f5f5;

  /* 全局基础 */
  background: #f5f6fa;
  font-size: 28rpx;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ===== 通用容器 ===== */
.container { padding: 20rpx; min-height: 100vh; box-sizing: border-box; overflow: visible; }

/* ===== 卡片 ===== */
.card {
  background: #fff; border-radius: 20rpx; padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

/* ===== 按钮 ===== */
.btn-primary {
  background: var(--primary-color); color: #fff;
  text-align: center; padding: 24rpx; border-radius: 48rpx;
  font-size: 30rpx; font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(74,144,217,0.2);
}
.btn-primary:active { opacity: 0.85; transform: scale(0.98); }
.btn-outline {
  border: 2rpx solid var(--primary-color); color: var(--primary-color);
  text-align: center; padding: 22rpx; border-radius: 48rpx;
  font-size: 30rpx; font-weight: 500; background: #fff;
}
.btn-danger {
  background: var(--danger-color); color: #fff;
  text-align: center; padding: 24rpx; border-radius: 48rpx;
  font-size: 30rpx; font-weight: 600;
}

/* ===== 输入框 ===== */
.input {
  border: 2rpx solid #e8eef6; border-radius: 14rpx; padding: 20rpx 24rpx;
  font-size: 28rpx; background: #f8fbff; min-height: 72rpx; line-height: 1.5;
}
.input:focus { border-color: var(--primary-color); }

/* ===== Flex ===== */
.flex { display: flex; }
.flex-1 { flex: 1; min-width: 0; }
.flex-center { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }

/* ===== 文字工具 ===== */
.text-gray { color: #999; }
.text-sm { font-size: 24rpx; }
.text-bold { font-weight: 600; }
.mt20 { margin-top: 20rpx; }
.mb20 { margin-bottom: 20rpx; }

/* ===== 头像 ===== */
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; border: 2rpx solid #f0f0f0; flex-shrink: 0; }
.avatar-placeholder {
  width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, #4A90D9, #6BB5F0);
  display: flex; align-items: center; justify-content: center;
}

/* ===== 标签 ===== */
.tag { font-size: 22rpx; background: #EBF3FC; color: var(--primary-color); padding: 6rpx 18rpx; border-radius: 20rpx; margin-right: 10rpx; font-weight: 500; }

/* ===== 空态 ===== */
.empty { text-align: center; padding: 120rpx 0; color: #bbb; font-size: 30rpx; }

/* ===== 全局 Vant 组件样式修正 ===== */
.van-button--primary { background: var(--primary-color) !important; border-color: var(--primary-color) !important; }
.van-button--round { border-radius: 999rpx !important; }
.van-empty__description { color: #bbb !important; font-size: 26rpx !important; }
.van-dialog__confirm { color: var(--primary-color) !important; }
.van-tab--active { color: var(--primary-color) !important; font-weight: 600 !important; }
.van-tabs__line { background: var(--primary-color) !important; }
.van-tag--success { background: var(--success-color) !important; }
.van-tag--warning { background: var(--warning-color) !important; }
