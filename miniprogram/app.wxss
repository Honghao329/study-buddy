@import "./utils/iconfont.wxss";
page { background: #f5f6fa; font-size: 28rpx; color: #333; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
.container { padding: 20rpx; min-height: 100vh; box-sizing: border-box; }
.card { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.btn-primary { background: linear-gradient(135deg, #4A90D9 0%, #6BB5F0 100%); color: #fff; text-align: center; padding: 24rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; box-shadow: 0 4rpx 16rpx rgba(74,144,217,0.25); }
.btn-primary:active { opacity: 0.85; }
.btn-outline { border: 2rpx solid #4A90D9; color: #4A90D9; text-align: center; padding: 22rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; background: #fff; }
.btn-danger { background: linear-gradient(135deg, #e91e63 0%, #ff5252 100%); color: #fff; text-align: center; padding: 24rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; }
.input { border: 2rpx solid #e8eef6; border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; background: #f8fbff; transition: border-color 0.3s; }
.input:focus { border-color: #4A90D9; }
.flex { display: flex; }
.flex-1 { flex: 1; }
.flex-center { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.text-gray { color: #999; }
.text-sm { font-size: 24rpx; }
.text-bold { font-weight: bold; }
.mt20 { margin-top: 20rpx; }
.mb20 { margin-bottom: 20rpx; }
.empty { text-align: center; padding: 120rpx 0; color: #bbb; font-size: 30rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%; border: 3rpx solid #EBF3FC; }
.tag { font-size: 22rpx; background: #EBF3FC; color: #4A90D9; padding: 6rpx 18rpx; border-radius: 20rpx; margin-right: 10rpx; font-weight: 500; }
