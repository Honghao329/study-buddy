<view class="container">
  <!-- Stats Card -->
  <view class="stats-card">
    <view class="stats-title">学习签到</view>
    <view class="stats-grid">
      <view class="stats-item">
        <view class="stats-num">{{stats.streak}}</view>
        <view class="stats-label">连续签到</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{stats.totalDays}}</view>
        <view class="stats-label">累计天数</view>
      </view>
      <view class="stats-item">
        <view class="stats-num">{{stats.totalDuration}}</view>
        <view class="stats-label">总时长(分)</view>
      </view>
    </view>
    <!-- 里程碑 -->
    <view class="milestone" wx:if="{{stats.streak > 0}}">
      <van-icon name="fire-o" size="16px" color="#FFD700" />
      <text wx:if="{{stats.streak >= 30}}">太厉害了！连续签到30天+</text>
      <text wx:elif="{{stats.streak >= 7}}">坚持得很好！距离30天还差{{30 - stats.streak}}天</text>
      <text wx:else>加油！距离7天连续签到还差{{7 - stats.streak}}天</text>
    </view>
    <view class="sign-btn {{stats.todaySigned ? 'signed' : ''}}" bindtap="openSignModal">
      {{stats.todaySigned ? '今日已签到 ✓' : '立即签到'}}
    </view>
  </view>

  <!-- Calendar -->
  <view class="card">
    <view class="cal-header flex-between">
      <text class="cal-arrow" bindtap="prevMonth"><van-icon name="arrow-left" size="16px" /></text>
      <text class="cal-title">{{year}}年{{month}}月</text>
      <text class="cal-arrow" bindtap="nextMonth"><van-icon name="arrow" size="16px" /></text>
    </view>
    <view class="cal-legend">
      <view class="legend-item"><view class="legend-dot green"></view><text>已签到</text></view>
      <view class="legend-item"><view class="legend-dot blue"></view><text>今天</text></view>
    </view>
    <view class="cal-weekdays">
      <view class="cal-wd" wx:for="{{weekDays}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="cal-grid">
      <view class="cal-day {{item.isToday ? 'today' : ''}} {{item.signed ? 'signed-day' : ''}} {{item.empty ? 'empty' : ''}}" wx:for="{{days}}" wx:key="index">
        <text>{{item.day}}</text>
        <view wx:if="{{item.signed}}" class="cal-check">
          <van-icon name="success" size="10px" color="#fff" />
        </view>
      </view>
    </view>
    <view class="cal-summary">
      本月已签到 <text class="cal-summary-num">{{monthSignCount}}</text> 天
    </view>
  </view>

  <!-- Rank -->
  <view class="card">
    <view class="section-title">签到排行榜</view>
    <van-empty wx:if="{{rankList.length === 0}}" description="暂无排行数据" />
    <view class="rank-item flex-center" wx:for="{{rankList}}" wx:key="user_id">
      <view class="rank-num {{index < 3 ? 'rank-top' : ''}}">{{index + 1}}</view>
      <image wx:if="{{item.user_pic}}" class="rank-avatar-img" src="{{item.user_pic}}" mode="aspectFill" />
      <view wx:else class="rank-avatar"><van-icon name="smile-o" size="22px" color="#fff" /></view>
      <view class="rank-info flex-1">
        <view class="rank-name">{{item.user_name || '学习者'}}</view>
        <view class="rank-sub">累计{{item.total_duration || 0}}分钟</view>
      </view>
      <view class="rank-days">{{item.days || 0}}天</view>
    </view>
  </view>

  <!-- 签到弹窗 -->
  <van-popup show="{{showModal}}" position="bottom" round bind:close="closeModal" safe-area-inset-bottom>
    <view class="popup-content">
      <view class="popup-title">学习签到</view>
      <view class="form-group">
        <view class="form-label">学习时长（分钟，选填）</view>
        <input class="sign-input" type="number" placeholder="如 60" value="{{duration}}" bindinput="onDurationInput" />
      </view>
      <view class="form-group">
        <view class="form-label">学习状态</view>
        <view class="status-tabs">
          <view class="status-tab {{statusIndex == 0 ? 'active green' : ''}}" bindtap="setStatus" data-idx="0">高效</view>
          <view class="status-tab {{statusIndex == 1 ? 'active blue' : ''}}" bindtap="setStatus" data-idx="1">一般</view>
          <view class="status-tab {{statusIndex == 2 ? 'active orange' : ''}}" bindtap="setStatus" data-idx="2">疲惫</view>
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">学习内容（选填）</view>
        <textarea class="sign-textarea" placeholder="今天学了什么？" value="{{content}}" bindinput="onContentInput" maxlength="200" auto-height />
      </view>
      <van-button type="primary" block round bind:click="doSign" custom-style="margin-top:20rpx">确认签到</van-button>
    </view>
  </van-popup>
</view>
