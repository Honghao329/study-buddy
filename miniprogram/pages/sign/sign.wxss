/* Stats Card */
.stats-card {
  background: linear-gradient(135deg, #4A90D9 0%, #6BB5F0 60%, #83C9F4 100%);
  border-radius: 24rpx; padding: 40rpx 36rpx;
  margin-bottom: 24rpx; color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(74,144,217,0.3);
  overflow: visible;
}
.stats-title { font-size: 36rpx; font-weight: bold; margin-bottom: 28rpx; line-height: 1.4; }
.stats-grid { display: flex; justify-content: space-around; margin-bottom: 20rpx; }
.stats-item { text-align: center; min-width: 0; }
.stats-num { font-size: 48rpx; font-weight: bold; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); line-height: 1.4; }
.stats-label { font-size: 22rpx; opacity: 0.85; margin-top: 6rpx; line-height: 1.4; }
.milestone {
  display: flex; align-items: center; gap: 8rpx; justify-content: center;
  font-size: 24rpx; opacity: 0.9; margin-bottom: 20rpx;
  background: rgba(255,255,255,0.15); border-radius: 20rpx; padding: 14rpx 20rpx;
  line-height: 1.5;
}
.sign-btn {
  background: rgba(255,255,255,0.3); text-align: center; padding: 22rpx;
  border-radius: 44rpx; font-size: 30rpx; font-weight: 600;
  line-height: 1.4; transition: all 0.3s;
}
.sign-btn:active { transform: scale(0.97); }
.sign-btn.signed { background: rgba(255,255,255,0.15); opacity: 0.7; }

/* Calendar */
.cal-header { padding: 12rpx 0 16rpx; }
.cal-arrow { font-size: 32rpx; color: #4A90D9; padding: 12rpx 24rpx; font-weight: bold; border-radius: 8rpx; }
.cal-arrow:active { background: #EBF3FC; }
.cal-title { font-size: 30rpx; font-weight: bold; color: #333; }
.cal-legend { display: flex; gap: 24rpx; justify-content: center; margin-bottom: 16rpx; }
.legend-item { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; color: #999; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.legend-dot.green { background: #4CAF50; }
.legend-dot.blue { background: #4A90D9; }
.cal-weekdays { display: flex; }
.cal-wd { width: 14.28%; text-align: center; font-size: 24rpx; color: #999; padding: 10rpx 0; }
.cal-grid { display: flex; flex-wrap: wrap; }
.cal-day {
  width: 14.28%; text-align: center; padding: 16rpx 0;
  position: relative; font-size: 28rpx; color: #555;
  line-height: 1.4; overflow: visible;
}
.cal-day.empty { color: transparent; }
.cal-day.today { color: #4A90D9; font-weight: bold; }
.cal-day.today::before {
  content: ''; position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -55%); width: 60rpx; height: 60rpx;
  background: #EBF3FC; border-radius: 50%; z-index: -1;
}
.cal-day.signed-day { color: #4CAF50; font-weight: bold; }
.cal-check {
  width: 24rpx; height: 24rpx; background: #4CAF50; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 4rpx auto 0;
}
.cal-summary { text-align: center; padding: 16rpx 0 4rpx; font-size: 24rpx; color: #999; }
.cal-summary-num { color: #4A90D9; font-weight: bold; font-size: 28rpx; }

/* Rank */
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }
.rank-item { padding: 18rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.rank-item:last-child { border-bottom: none; }
.rank-num { width: 48rpx; height: 48rpx; line-height: 48rpx; text-align: center; font-size: 24rpx; color: #999; margin-right: 16rpx; border-radius: 50%; flex-shrink: 0; }
.rank-top { background: linear-gradient(135deg, #4A90D9, #6BB5F0); color: #fff; font-weight: bold; }
.rank-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.rank-avatar-img { width: 56rpx; height: 56rpx; border-radius: 50%; margin-right: 16rpx; flex-shrink: 0; }
.rank-info { margin-left: 4rpx; }
.rank-name { font-size: 28rpx; font-weight: 500; }
.rank-sub { font-size: 22rpx; color: #999; margin-top: 2rpx; }
.rank-days { font-size: 26rpx; color: #4A90D9; font-weight: bold; background: #EBF3FC; padding: 6rpx 20rpx; border-radius: 20rpx; }

/* Popup */
.popup-content { padding: 36rpx; }
.popup-title { font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 28rpx; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; font-weight: 500; }
.sign-input {
  border: 2rpx solid #e8eef6; border-radius: 12rpx; padding: 20rpx;
  font-size: 28rpx; background: #f8fbff; width: 100%; box-sizing: border-box;
  height: auto; min-height: 72rpx; line-height: 1.5;
}
.sign-textarea {
  border: 2rpx solid #e8eef6; border-radius: 12rpx; padding: 20rpx;
  font-size: 28rpx; background: #f8fbff; width: 100%; box-sizing: border-box;
  min-height: 100rpx;
}
.status-tabs { display: flex; gap: 16rpx; }
.status-tab {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx;
  font-size: 26rpx; color: #666; background: #f5f6fa; transition: all 0.2s;
}
.status-tab.active.green { background: #E8F5E9; color: #4CAF50; font-weight: bold; }
.status-tab.active.blue { background: #EBF3FC; color: #4A90D9; font-weight: bold; }
.status-tab.active.orange { background: #FFF3E0; color: #FF9800; font-weight: bold; }
