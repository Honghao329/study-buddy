/* Stats Card */
.stats-card {
  background: linear-gradient(135deg, #4A90D9 0%, #6BB5F0 60%, #83C9F4 100%);
  border-radius: 24rpx;
  padding: 44rpx 36rpx;
  margin-bottom: 24rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(74,144,217,0.3);
}
.stats-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
}
.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 36rpx;
}
.stats-item {
  text-align: center;
}
.stats-num {
  font-size: 48rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.stats-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}
.sign-btn {
  background: rgba(255,255,255,0.3);
  text-align: center;
  padding: 20rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s;
}
.sign-btn:active {
  transform: scale(0.97);
}
.sign-btn.signed {
  background: rgba(255,255,255,0.15);
  opacity: 0.7;
}

/* Calendar */
.cal-header {
  padding: 12rpx 0 24rpx;
}
.cal-arrow {
  font-size: 32rpx;
  color: #4A90D9;
  padding: 12rpx 24rpx;
  font-weight: bold;
  border-radius: 8rpx;
  transition: all 0.2s;
}
.cal-arrow:active {
  background: #EBF3FC;
}
.cal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
.cal-weekdays {
  display: flex;
}
.cal-wd {
  width: 14.28%;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
}
.cal-grid {
  display: flex;
  flex-wrap: wrap;
}
.cal-day {
  width: 14.28%;
  text-align: center;
  padding: 18rpx 0;
  position: relative;
  font-size: 28rpx;
  color: #555;
}
.cal-day.empty {
  color: transparent;
}
.cal-day.today {
  color: #4A90D9;
  font-weight: bold;
}
.cal-day.today::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  width: 60rpx;
  height: 60rpx;
  background: #EBF3FC;
  border-radius: 50%;
  z-index: -1;
}
.cal-dot {
  width: 10rpx;
  height: 10rpx;
  background: #4CAF50;
  border-radius: 50%;
  margin: 6rpx auto 0;
}

/* Rank */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}
.rank-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.rank-item:last-child {
  border-bottom: none;
}
.rank-num {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
  border-radius: 50%;
}
.rank-top {
  background: linear-gradient(135deg, #4A90D9 0%, #6BB5F0 100%);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(74,144,217,0.3);
}
.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8EEF6 0%, #D6E8F9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.rank-info {
  margin-left: 16rpx;
}
.rank-name {
  font-size: 28rpx;
  font-weight: 500;
}
.rank-days {
  font-size: 26rpx;
  color: #4A90D9;
  font-weight: bold;
  background: #EBF3FC;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* Rank Avatar */
.rank-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx; font-weight: bold;
  margin-right: 12rpx; flex-shrink: 0;
}

/* Modal */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 999;
  display: flex; align-items: center; justify-content: center;
}
.modal-box {
  width: 85%; background: #fff; border-radius: 24rpx;
  padding: 44rpx; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
}
.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 36rpx;
  color: #333;
}
.modal-btns {
  margin-top: 36rpx;
}
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.picker-value {
  display: flex;
  align-items: center;
  min-height: 36rpx;
}
