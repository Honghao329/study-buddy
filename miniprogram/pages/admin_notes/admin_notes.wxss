.search-bar {
  margin-bottom: 20rpx;
  gap: 16rpx;
}
.search-btn {
  background: #4A90D9;
  color: #fff;
  padding: 18rpx 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  white-space: nowrap;
}
.note-item {
  padding: 24rpx 30rpx;
}
.note-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-right: 16rpx;
}
.del-btn {
  color: #e91e63;
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid #e91e63;
  border-radius: 8rpx;
  white-space: nowrap;
}
.note-meta {
  margin-top: 12rpx;
}
.note-stats {
  margin-top: 8rpx;
}
.meta-sep {
  margin: 0 12rpx;
  color: #ddd;
}
.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}
