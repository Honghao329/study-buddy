<view class="container">
  <!-- Search -->
  <view class="search-bar flex">
    <input class="input flex-1" placeholder="搜索笔记标题" value="{{search}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="doSearch" />
    <view class="search-btn" bindtap="doSearch">
      <van-icon name="search" size="16px" /> 搜索
    </view>
  </view>

  <!-- List -->
  <van-empty wx:if="{{list.length === 0 && !loading}}" description="暂无笔记数据" />

  <view class="card note-item" wx:for="{{list}}" wx:key="id">
    <view class="flex-between">
      <view class="note-title flex-1">{{item.title || '无标题'}}</view>
      <view class="del-btn" bindtap="deleteNote" data-id="{{item.id}}">
        <van-icon name="cross" size="14px" color="#ff4757" /> 删除
      </view>
    </view>
    <view class="note-meta text-sm text-gray">
      <text>作者: {{item.authorName || item.nickName || '未知'}}</text>
      <text class="meta-sep">|</text>
      <text>{{item.createdAt || ''}}</text>
    </view>
    <view class="note-stats text-sm text-gray" wx:if="{{item.viewCount !== undefined}}">
      <van-icon name="eye-o" size="12px" /> {{item.viewCount || 0}}
      <text class="meta-sep">|</text>
      <van-icon name="good-job-o" size="12px" /> {{item.likeCount || 0}}
      <text class="meta-sep">|</text>
      <van-icon name="chat-o" size="12px" /> {{item.commentCount || 0}}
    </view>
  </view>

  <van-loading wx:if="{{loading}}" size="24px" vertical>加载中...</van-loading>
  <van-divider wx:if="{{!hasMore && list.length > 0}}" contentPosition="center">没有更多了</van-divider>
</view>
