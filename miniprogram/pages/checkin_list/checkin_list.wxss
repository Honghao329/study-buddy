/* Search Bar */
.search-bar {
  padding: 10rpx 0 20rpx;
}
.search-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(74,144,217,0.08);
  border: 1rpx solid #EBF3FC;
}
.search-icon-text {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
}
.search-clear {
  color: #999;
  font-size: 32rpx;
  padding: 0 10rpx;
  font-weight: bold;
}

/* Checkin Card */
.checkin-card {
  position: relative;
  border-left: 6rpx solid #4A90D9;
  transition: all 0.2s;
}
.checkin-card:active {
  background: #f8fbff;
}
.checkin-title {
  font-size: 32rpx;
  line-height: 1.4;
  color: #222;
}
.checkin-desc {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.7;
}
.checkin-date {
  color: #4A90D9;
  font-weight: 500;
}
.join-count {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #EBF3FC;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.join-icon {
  font-size: 24rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}
