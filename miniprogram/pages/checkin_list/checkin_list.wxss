/* Search */
.search-bar { padding: 10rpx 0 12rpx; }
.search-wrap { display: flex; align-items: center; background: #fff; border-radius: 40rpx; padding: 14rpx 24rpx; box-shadow: 0 2rpx 12rpx rgba(74,144,217,0.08); border: 1rpx solid #EBF3FC; }
.search-input { flex: 1; font-size: 28rpx; min-height: 48rpx; line-height: 1.5; }
.search-clear { color: #999; padding: 0 10rpx; }

/* Filter tabs */
.filter-tabs { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.filter-tab {
  font-size: 26rpx; color: #666; background: #fff;
  padding: 10rpx 24rpx; border-radius: 24rpx;
  border: 1rpx solid #e8eef6; transition: all 0.2s;
}
.filter-tab.active { background: #4A90D9; color: #fff; border-color: #4A90D9; }

/* Checkin Card */
.checkin-card { position: relative; border-left: 6rpx solid #4A90D9; transition: all 0.2s; }
.checkin-card:active { background: #f8fbff; }
.checkin-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.checkin-title { font-size: 32rpx; line-height: 1.4; color: #222; flex: 1; }
.checkin-desc { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; line-height: 1.7; }
.checkin-date { color: #4A90D9; font-weight: 500; }
.join-count { display: flex; align-items: center; gap: 6rpx; background: #EBF3FC; padding: 6rpx 16rpx; border-radius: 20rpx; }

/* FAB */
.fab {
  position: fixed; right: 40rpx; bottom: 140rpx;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9, #667eea);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74,144,217,0.4);
  z-index: 10;
}

/* Popup */
.popup-content { padding: 36rpx; }
.popup-title { font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 28rpx; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; }
.form-input {
  border: 2rpx solid #e8eef6; border-radius: 12rpx; padding: 20rpx;
  font-size: 28rpx; background: #f8fbff; width: 100%; box-sizing: border-box;
  height: auto; min-height: 72rpx; line-height: 1.5;
}
.form-textarea {
  border: 2rpx solid #e8eef6; border-radius: 12rpx; padding: 20rpx;
  font-size: 28rpx; background: #f8fbff; width: 100%; box-sizing: border-box;
  min-height: 100rpx;
}
.form-row { display: flex; gap: 16rpx; }
.form-half { flex: 1; }
.picker-val { color: #555; }
