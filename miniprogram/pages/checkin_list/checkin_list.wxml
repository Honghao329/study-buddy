<view class="container">
  <!-- 搜索 -->
  <view class="search-bar">
    <view class="search-wrap">
      <van-icon name="search" size="16px" color="#999" />
      <input class="search-input" placeholder="搜索打卡任务..." value="{{search}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
      <view class="search-clear" wx:if="{{search}}" bindtap="onClearSearch"><van-icon name="cross" size="14px" color="#999" /></view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view class="filter-tab {{filter === '' ? 'active' : ''}}" bindtap="setFilter" data-v="">全部</view>
    <view class="filter-tab {{filter === 'joined' ? 'active' : ''}}" bindtap="setFilter" data-v="joined">我参与的</view>
    <view class="filter-tab {{filter === 'supervising' ? 'active' : ''}}" bindtap="setFilter" data-v="supervising">我监督的</view>
  </view>

  <!-- 列表 -->
  <view wx:if="{{list.length > 0}}">
    <view class="card checkin-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="checkin-header">
        <view class="checkin-title text-bold">{{item.title}}</view>
        <van-tag wx:if="{{item._joined}}" type="success" size="small">已参与</van-tag>
        <van-tag wx:if="{{item._supervising}}" type="warning" size="small">监督中</van-tag>
      </view>
      <view class="checkin-desc text-gray text-sm" wx:if="{{item.description}}">{{item.description}}</view>
      <view class="flex-between mt20">
        <view class="checkin-date text-sm text-gray" wx:if="{{item.start_date}}">{{item.start_date}} ~ {{item.end_date}}</view>
        <view class="join-count text-sm">
          <van-icon name="friends-o" size="14px" color="#4CAF50" />
          <text class="text-gray">{{item.join_cnt || 0}} 人</text>
        </view>
      </view>
    </view>
  </view>

  <van-empty wx:if="{{!loading && list.length === 0}}" description="暂无打卡任务" />
  <van-loading wx:if="{{loading}}" size="24px" vertical>加载中...</van-loading>
  <van-divider wx:if="{{!hasMore && list.length > 0}}" contentPosition="center">没有更多了</van-divider>

  <!-- 创建按钮 -->
  <view class="fab" bindtap="openCreate">
    <van-icon name="plus" size="24px" color="#fff" />
  </view>

  <!-- 创建弹窗 -->
  <van-popup show="{{showCreate}}" position="bottom" round bind:close="closeCreate" safe-area-inset-bottom>
    <view class="popup-content">
      <view class="popup-title">创建打卡任务</view>
      <view class="form-group">
        <view class="form-label">任务标题</view>
        <input class="form-input" placeholder="如：每日英语打卡" value="{{createForm.title}}" bindinput="onCreateTitle" maxlength="30" />
      </view>
      <view class="form-group">
        <view class="form-label">任务描述（选填）</view>
        <textarea class="form-textarea" placeholder="描述一下打卡内容..." value="{{createForm.description}}" bindinput="onCreateDesc" maxlength="200" auto-height />
      </view>
      <view class="form-row">
        <view class="form-group form-half">
          <view class="form-label">开始日期</view>
          <picker mode="date" value="{{createForm.start_date}}" bindchange="onStartDate">
            <view class="form-input picker-val">{{createForm.start_date || '请选择'}}</view>
          </picker>
        </view>
        <view class="form-group form-half">
          <view class="form-label">结束日期</view>
          <picker mode="date" value="{{createForm.end_date}}" bindchange="onEndDate">
            <view class="form-input picker-val">{{createForm.end_date || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <van-button type="primary" block round bind:click="doCreate" loading="{{creating}}" custom-style="margin-top:20rpx">创建任务</van-button>
    </view>
  </van-popup>
</view>
