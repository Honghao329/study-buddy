<view class="container">
  <van-cell-group wx:if="{{list.length > 0}}">
	    <van-cell
	      wx:for="{{list}}"
	      wx:for-index="index"
	      wx:for-item="item"
	      wx:key="id"
	      title="{{item.title}}"
	      label="{{item.createdAt || item.created_at}}"
	      is-link
	      data-index="{{index}}"
	      bindtap="onTapItem"
	      bindlongpress="onDeleteItem"
	    >
	      <van-tag slot="right-icon" plain type="primary" custom-class="fav-tag">{{item.targetType === 'note' ? '笔记' : item.targetType}}</van-tag>
	    </van-cell>
  </van-cell-group>

  <van-empty wx:if="{{!loading && list.length === 0}}" description="暂无收藏" />
  <van-loading wx:if="{{loading}}" size="24px" vertical custom-class="loading-wrap">加载中...</van-loading>
</view>
