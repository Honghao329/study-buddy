<view class="container">
  <van-cell-group wx:if="{{list.length > 0}}">
    <van-cell
      wx:for="{{list}}"
      wx:key="id"
      title="{{item.title}}"
      label="{{item.created_at}}"
      is-link
      data-item="{{item}}"
      bindtap="onTapItem"
      bindlongpress="onDeleteItem"
    >
      <van-tag slot="right-icon" plain type="primary" custom-class="fav-tag">{{item.target_type === 'note' ? '笔记' : item.target_type}}</van-tag>
    </van-cell>
  </van-cell-group>

  <van-empty wx:if="{{!loading && list.length === 0}}" description="暂无收藏" />
  <van-loading wx:if="{{loading}}" size="24px" vertical custom-class="loading-wrap">加载中...</van-loading>
</view>
