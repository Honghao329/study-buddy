<view class="container">
  <van-empty wx:if="{{!loading && list.length === 0}}" description="暂无收藏，去社区看看吧" />

  <view class="fav-card card" wx:for="{{list}}" wx:key="id">
    <view class="fav-body" bindtap="onTapItem" data-index="{{index}}">
      <view class="fav-title">{{item.title || '未知内容'}}</view>
      <view class="fav-meta">
        <van-tag plain type="primary" size="small">{{item.targetType === 'note' ? '笔记' : item.targetType}}</van-tag>
        <text class="fav-time text-sm text-gray">{{item.createdAt || item.created_at}}</text>
      </view>
    </view>
    <view class="fav-del" catchtap="onDeleteItem" data-index="{{index}}">
      <van-icon name="delete-o" size="20px" color="#f56c6c" />
    </view>
  </view>

  <van-loading wx:if="{{loading}}" size="24px" vertical custom-class="loading-wrap">加载中...</van-loading>
</view>
