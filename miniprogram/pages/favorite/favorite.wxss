.container { padding: 20rpx 0; min-height: 100vh; background: #f5f6fa; }

.fav-card {
  display: flex; align-items: center; padding: 24rpx 30rpx; margin-bottom: 12rpx;
}
.fav-body { flex: 1; }
.fav-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 10rpx; }
.fav-meta { display: flex; align-items: center; gap: 12rpx; }
.fav-time { margin-left: 4rpx; }
.fav-del { padding: 16rpx; margin-left: 12rpx; }

.loading-wrap { padding-top: 200rpx; text-align: center; }
