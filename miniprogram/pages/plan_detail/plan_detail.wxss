/* Calendar Card */
.calendar-card {
  padding: 24rpx 20rpx;
}
.cal-header {
  padding: 10rpx 10rpx 20rpx;
}
.cal-month-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.cal-weekdays {
  border-bottom: 1rpx solid #f0f4f8;
  padding-bottom: 16rpx;
  margin-bottom: 10rpx;
}
.cal-weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}
.cal-grid {
  display: flex;
  flex-wrap: wrap;
}
.cal-day {
  width: 14.2857%;
  text-align: center;
  padding: 16rpx 0 20rpx;
  font-size: 28rpx;
  color: #333;
  position: relative;
  box-sizing: border-box;
}
.cal-empty {
  color: transparent;
}
.cal-today {
  color: #fff;
  font-weight: bold;
}
.cal-today::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #4A90D9, #6BB5F0);
  border-radius: 50%;
  z-index: 0;
}
.cal-today text {
  position: relative;
  z-index: 1;
}
.cal-dot {
  width: 10rpx;
  height: 10rpx;
  background: #4CAF50;
  border-radius: 50%;
  position: absolute;
  bottom: 6rpx;
  left: 50%;
  transform: translateX(-50%);
}
.cal-checked .cal-dot {
  background: #4CAF50;
}

/* Section Title */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 24rpx;
}

/* Detail Info */
.detail-info-card {
  padding: 30rpx;
}
.detail-row {
  gap: 10rpx;
}
.detail-item {
  flex: 1;
  text-align: center;
}
.detail-label {
  margin-bottom: 8rpx;
}
.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.detail-desc {
  line-height: 1.6;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f4f8;
}
.creator-row {
  text-align: right;
}
.creator-name {
  color: #4A90D9;
  font-weight: 500;
}

/* People Card */
.people-card {
  padding: 30rpx 20rpx;
}
.people-pair {
  align-items: center;
}
.people-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.people-role-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}
.people-avatar-wrap {
  position: relative;
}
.people-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid #EBF3FC;
}
.people-avatar-fallback {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.executor-fb {
  background: linear-gradient(135deg, #4A90D9, #6BB5F0);
}
.supervisor-fb {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}
.people-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.people-chain {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}
.chain-circle {
  width: 70rpx;
  height: 70rpx;
  background: #f0f6ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #c5d9f0;
}

/* Stats Section */
.stats-section {
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-number {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.stat-text {
  font-size: 22rpx;
  color: #999;
}
.stat-blue .stat-number {
  color: #4A90D9;
}
.stat-blue {
  border-top: 4rpx solid #4A90D9;
}
.stat-orange .stat-number {
  color: #FF9800;
}
.stat-orange {
  border-top: 4rpx solid #FF9800;
}
.stat-green .stat-number {
  color: #4CAF50;
  font-size: 26rpx;
}
.stat-green {
  border-top: 4rpx solid #4CAF50;
}

/* Records Timeline */
.records-card {
  padding: 30rpx 20rpx;
}
.timeline {
  position: relative;
}
.timeline-item {
  display: flex;
  margin-bottom: 30rpx;
  position: relative;
}
.timeline-left {
  width: 100rpx;
  position: relative;
  flex-shrink: 0;
}
.timeline-date {
  font-weight: 600;
  color: #4A90D9;
  line-height: 1.4;
}
.timeline-line {
  position: absolute;
  left: 40rpx;
  top: 50rpx;
  bottom: -30rpx;
  width: 2rpx;
  background: #e8eef6;
}
.timeline-item:last-child .timeline-line {
  display: none;
}
.timeline-right {
  background: #f8fbff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-left: 16rpx;
}
.timeline-header {
  margin-bottom: 12rpx;
  gap: 12rpx;
}
.timeline-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #EBF3FC;
}
.timeline-avatar-ph {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #EBF3FC;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timeline-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}
.timeline-time {
  margin-left: auto;
}
.timeline-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
}
.timeline-images {
  margin-top: 16rpx;
  gap: 12rpx;
  flex-wrap: wrap;
}
.timeline-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
}
.timeline-comment {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF9800;
}
.comment-label {
  margin-bottom: 6rpx;
}
.comment-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  margin-bottom: 8rpx;
}
.timeline-actions {
  display: flex;
  gap: 16rpx;
}
.load-more {
  text-align: center;
  padding: 20rpx;
}

/* Bottom Bar */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}

/* Popup */
.popup-content {
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}
.popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 30rpx;
  text-align: center;
}
.score-row {
  gap: 16rpx;
}
.score-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}
