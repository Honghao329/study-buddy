<view class="container">

  <!-- Section 1: Calendar -->
  <view class="card calendar-card">
    <view class="cal-header flex-between">
      <van-icon name="arrow-left" size="18px" color="#4A90D9" bindtap="prevMonth" />
      <view class="cal-month-label">{{monthLabel}}</view>
      <van-icon name="arrow" size="18px" color="#4A90D9" bindtap="nextMonth" />
    </view>
    <view class="cal-weekdays flex">
      <view class="cal-weekday" wx:for="{{weekDays}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="cal-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="index"
        class="cal-day {{item.isToday ? 'cal-today' : ''}} {{item.checked ? 'cal-checked' : ''}} {{item.empty ? 'cal-empty' : ''}}"
      >
        <text wx:if="{{!item.empty}}">{{item.day}}</text>
        <view wx:if="{{item.checked}}" class="cal-dot"></view>
      </view>
    </view>
  </view>

  <!-- Section 2: Plan Detail Info -->
  <view class="card detail-info-card">
    <view class="section-title">计划详情</view>
    <view class="detail-row flex-between">
      <view class="detail-item">
        <view class="detail-label text-sm text-gray">打卡频次</view>
        <view class="detail-value">{{plan.frequencyLabel || '每天'}}</view>
      </view>
      <view class="detail-item">
        <view class="detail-label text-sm text-gray">打卡分类</view>
        <view class="detail-value">{{plan.category || '未分类'}}</view>
      </view>
      <view class="detail-item">
        <view class="detail-label text-sm text-gray">提醒时间</view>
        <view class="detail-value">{{plan.remind_time || '未设置'}}</view>
      </view>
    </view>
    <view wx:if="{{plan.description}}" class="detail-desc text-sm text-gray mt20">{{plan.description}}</view>
    <view wx:if="{{plan.creator_name}}" class="creator-row text-sm text-gray mt20">
      创建者: <text class="creator-name">{{plan.creator_name}}</text>
    </view>
  </view>

  <!-- Section 3: Executor & Supervisor -->
  <view class="card people-card">
    <view class="people-pair flex">
      <view class="people-col flex-1">
        <view class="people-role-label">执行者</view>
        <view class="people-avatar-wrap">
          <image wx:if="{{plan.executor_avatar}}" class="people-avatar" src="{{plan.executor_avatar}}" mode="aspectFill"></image>
          <view wx:else class="people-avatar-fallback executor-fb">
            <van-icon name="contact" size="28px" color="#fff" />
          </view>
        </view>
        <view class="people-name">{{plan.executor_name || '执行者'}}</view>
      </view>
      <view class="people-chain">
        <view class="chain-circle">
          <van-icon name="link-o" size="22px" color="#4A90D9" />
        </view>
      </view>
      <view class="people-col flex-1">
        <view class="people-role-label">监督者</view>
        <view class="people-avatar-wrap">
          <image wx:if="{{plan.supervisor_avatar}}" class="people-avatar" src="{{plan.supervisor_avatar}}" mode="aspectFill"></image>
          <view wx:else class="people-avatar-fallback supervisor-fb">
            <van-icon name="contact" size="28px" color="#fff" />
          </view>
        </view>
        <view class="people-name">{{plan.supervisor_name || '监督者'}}</view>
      </view>
    </view>
  </view>

  <!-- Section 4: My Stats -->
  <view class="stats-section flex">
    <view class="stat-card stat-blue flex-1">
      <view class="stat-number">{{plan.checkin_days || 0}}</view>
      <view class="stat-text">已打卡(天)</view>
    </view>
    <view class="stat-card stat-orange flex-1">
      <view class="stat-number">{{plan.total_score || 0}}</view>
      <view class="stat-text">积分</view>
    </view>
    <view class="stat-card stat-green flex-1">
      <view class="stat-number">{{plan.reward || '未设置'}}</view>
      <view class="stat-text">奖励</view>
    </view>
  </view>

  <!-- Section 5: Records Timeline -->
  <view class="card records-card">
    <view class="section-title">打卡记录</view>
    <van-empty wx:if="{{records.length === 0 && !loadingRecords}}" description="暂无打卡记录" />

    <view class="timeline" wx:if="{{records.length > 0}}">
      <view class="timeline-item" wx:for="{{records}}" wx:key="id">
        <view class="timeline-left">
          <view class="timeline-date text-sm">{{item.dateLabel}}</view>
          <view class="timeline-line"></view>
        </view>
        <view class="timeline-right flex-1">
          <view class="timeline-header flex-center">
            <image wx:if="{{item.user_avatar}}" class="timeline-avatar" src="{{item.user_avatar}}" mode="aspectFill"></image>
            <view wx:else class="timeline-avatar-ph">
              <van-icon name="contact" size="16px" color="#4A90D9" />
            </view>
            <view class="timeline-name">{{item.user_name || '用户'}}</view>
            <view class="timeline-time text-sm text-gray">{{item.timeLabel}}</view>
          </view>
          <view class="timeline-content">{{item.content}}</view>
          <!-- Images -->
          <view wx:if="{{item.images && item.images.length > 0}}" class="timeline-images flex">
            <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" class="timeline-img" src="{{img}}" mode="aspectFill"></image>
          </view>
          <!-- Comment display -->
          <view wx:if="{{item.comment}}" class="timeline-comment">
            <view class="comment-label text-sm text-gray">监督评语:</view>
            <view class="comment-text">{{item.comment}}</view>
            <van-tag wx:if="{{item.score}}" type="warning" round size="medium">{{item.score}}分</van-tag>
          </view>
          <!-- Supervisor actions -->
          <view wx:if="{{isSupervisor && !item.comment}}" class="timeline-actions mt20">
            <van-button size="mini" type="info" plain round bindtap="openComment" data-id="{{item.id}}">评论/评分</van-button>
          </view>
        </view>
      </view>
    </view>

    <van-loading wx:if="{{loadingRecords}}" size="20px" vertical>加载中...</van-loading>
    <view wx:if="{{records.length > 0 && hasMoreRecords}}" class="load-more text-sm text-gray" bindtap="loadMoreRecords">加载更多</view>
    <van-divider wx:if="{{records.length > 0 && !hasMoreRecords}}" contentPosition="center">没有更多了</van-divider>
  </view>

  <!-- Bottom spacer for fixed button -->
  <view style="height: 120rpx;"></view>

  <!-- Section 6: Bottom Action -->
  <view wx:if="{{isExecutor}}" class="bottom-bar">
    <van-button
      wx:if="{{!todayChecked}}"
      type="info"
      block
      round
      bindtap="openCheckin"
      custom-style="font-weight:600;font-size:32rpx;"
    >打卡</van-button>
    <van-button
      wx:else
      type="info"
      block
      round
      disabled
      custom-style="font-weight:600;font-size:32rpx;"
    >今日已打卡</van-button>
  </view>

  <!-- Checkin Popup -->
  <van-popup show="{{showCheckin}}" position="bottom" round closeable bind:close="closeCheckin">
    <view class="popup-content">
      <view class="popup-title">今日打卡</view>
      <van-field
        value="{{checkinContent}}"
        type="textarea"
        placeholder="记录你今天的完成情况..."
        autosize="{{ {minHeight: 120} }}"
        bind:change="onCheckinInput"
        border="{{false}}"
      />
      <van-button type="info" block round bindtap="submitCheckin" custom-style="margin-top:30rpx;font-weight:600;">提交打卡</van-button>
    </view>
  </van-popup>

  <!-- Comment Popup -->
  <van-popup show="{{showComment}}" position="bottom" round closeable bind:close="closeComment">
    <view class="popup-content">
      <view class="popup-title">评论 & 评分</view>
      <van-field
        value="{{commentText}}"
        type="textarea"
        placeholder="给执行者写一段评语..."
        autosize="{{ {minHeight: 100} }}"
        bind:change="onCommentInput"
        border="{{false}}"
      />
      <view class="score-row flex-center mt20">
        <text class="score-label">评分:</text>
        <van-rate value="{{commentScore}}" bind:change="onScoreChange" size="24" color="#FF9800" void-color="#eee" />
      </view>
      <van-button type="info" block round bindtap="submitComment" custom-style="margin-top:30rpx;font-weight:600;">提交评论</van-button>
    </view>
  </van-popup>

</view>
