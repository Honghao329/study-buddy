<view class="container">
  <view class="form-section">

    <!-- Title -->
    <view class="card form-card">
      <view class="form-label">计划名称 <text class="required">*</text></view>
      <van-field
        value="{{title}}"
        placeholder="输入计划名称..."
        bind:change="onTitleInput"
        border="{{false}}"
        clearable
      />
    </view>

    <!-- Description -->
    <view class="card form-card">
      <view class="form-label">计划描述</view>
      <van-field
        value="{{description}}"
        type="textarea"
        placeholder="描述一下你的计划..."
        autosize="{{ {minHeight: 80} }}"
        bind:change="onDescInput"
        border="{{false}}"
      />
    </view>

    <!-- Frequency -->
    <view class="card form-card" bindtap="openFreqPicker">
      <view class="form-row flex-between">
        <view class="form-label no-margin">打卡频次</view>
        <view class="form-value flex-center">
          <text>{{frequency}}</text>
          <van-icon name="arrow" size="14px" color="#999" />
        </view>
      </view>
    </view>

    <!-- Category -->
    <view class="card form-card" bindtap="openCatPicker">
      <view class="form-row flex-between">
        <view class="form-label no-margin">分类</view>
        <view class="form-value flex-center">
          <text>{{category}}</text>
          <van-icon name="arrow" size="14px" color="#999" />
        </view>
      </view>
    </view>

    <!-- Partner Selection -->
    <view class="card form-card">
      <view class="form-label">选择伙伴 <text class="required">*</text></view>
      <van-empty wx:if="{{partners.length === 0}}" description="暂无伙伴，请先邀请" image="search" />
      <view class="partner-list">
        <view
          class="partner-option {{partnerId === item.id ? 'partner-selected' : ''}}"
          wx:for="{{partners}}"
          wx:key="id"
          bindtap="selectPartner"
          data-id="{{item.id}}"
          data-name="{{item.nickName}}"
        >
          <image wx:if="{{item.avatarUrl}}" class="partner-opt-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="partner-opt-avatar-ph">
            <van-icon name="contact" size="18px" color="#4A90D9" />
          </view>
          <view class="partner-opt-name">{{item.nickName}}</view>
          <van-icon wx:if="{{partnerId === item.id}}" name="success" size="18px" color="#4A90D9" />
        </view>
      </view>
    </view>

    <!-- Role -->
    <view class="card form-card">
      <view class="form-label">我的角色</view>
      <van-radio-group value="{{iAmExecutor ? 'executor' : 'supervisor'}}" bind:change="onRoleChange" direction="horizontal">
        <van-radio name="executor" icon-size="18px" checked-color="#4A90D9">我是执行者</van-radio>
        <van-radio name="supervisor" icon-size="18px" checked-color="#FF9800">我是监督者</van-radio>
      </van-radio-group>
      <view class="role-hint text-sm text-gray mt20">
        <text wx:if="{{iAmExecutor}}">你将负责打卡，伙伴负责监督和评分</text>
        <text wx:else>你将负责监督和评分，伙伴负责打卡</text>
      </view>
    </view>

    <!-- Reward -->
    <view class="card form-card">
      <view class="form-label">奖励 (选填)</view>
      <van-field
        value="{{reward}}"
        placeholder="完成计划后的奖励..."
        bind:change="onRewardInput"
        border="{{false}}"
        clearable
      />
    </view>

    <!-- Remind Time -->
    <view class="card form-card" bindtap="openTimePicker">
      <view class="form-row flex-between">
        <view class="form-label no-margin">提醒时间 (选填)</view>
        <view class="form-value flex-center">
          <text>{{remindTime || '未设置'}}</text>
          <van-icon name="arrow" size="14px" color="#999" />
        </view>
      </view>
    </view>

  </view>

  <!-- Submit -->
  <van-button
    type="info"
    block
    round
    loading="{{submitting}}"
    disabled="{{submitting}}"
    bindtap="submit"
    custom-style="margin-top:40rpx;font-weight:600;font-size:32rpx;"
  >创建计划</van-button>

  <!-- Frequency Picker Popup -->
  <van-popup show="{{showFreqPicker}}" position="bottom" round bind:close="closeFreqPicker">
    <van-picker
      columns="{{frequencyOptions}}"
      show-toolbar
      title="选择频次"
      bind:confirm="onFreqConfirm"
      bind:cancel="closeFreqPicker"
    />
  </van-popup>

  <!-- Category Picker Popup -->
  <van-popup show="{{showCatPicker}}" position="bottom" round bind:close="closeCatPicker">
    <van-picker
      columns="{{categoryOptions}}"
      show-toolbar
      title="选择分类"
      bind:confirm="onCatConfirm"
      bind:cancel="closeCatPicker"
    />
  </van-popup>

  <!-- Time Picker Popup -->
  <van-popup show="{{showTimePicker}}" position="bottom" round bind:close="closeTimePicker">
    <van-datetime-picker
      type="time"
      value="{{currentTime}}"
      bind:confirm="onTimeConfirm"
      bind:cancel="closeTimePicker"
      title="选择提醒时间"
    />
  </van-popup>

</view>
