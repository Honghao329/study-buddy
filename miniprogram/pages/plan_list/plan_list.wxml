<view class="container">
  <!-- Header -->
  <view class="page-header flex-between">
    <view class="page-title">我的计划</view>
    <van-button type="info" size="small" round icon="plus" bindtap="goCreate">创建计划</van-button>
  </view>

  <!-- Loading -->
  <van-loading wx:if="{{loading}}" size="24px" vertical class="loading-wrap">加载中...</van-loading>

  <!-- Plan List -->
  <block wx:if="{{!loading}}">
    <van-empty wx:if="{{list.length === 0}}" description="暂无监督打卡计划" />

    <view class="plan-card card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <!-- Title + Category -->
      <view class="flex-between">
        <view class="plan-title">{{item.title}}</view>
        <van-tag type="primary" round wx:if="{{item.category}}">{{item.category}}</van-tag>
      </view>

      <!-- Avatars: executor <-> supervisor -->
      <view class="avatar-pair">
        <view class="avatar-col">
          <image wx:if="{{item.executor_avatar}}" class="pair-avatar" src="{{item.executor_avatar}}" mode="aspectFill"></image>
          <view wx:else class="pair-avatar-placeholder">
            <van-icon name="contact" size="24px" color="#4A90D9" />
          </view>
          <view class="avatar-label text-sm text-gray">{{item.executor_name || '执行者'}}</view>
        </view>
        <view class="chain-icon">
          <van-icon name="link-o" size="20px" color="#4A90D9" />
        </view>
        <view class="avatar-col">
          <image wx:if="{{item.supervisor_avatar}}" class="pair-avatar" src="{{item.supervisor_avatar}}" mode="aspectFill"></image>
          <view wx:else class="pair-avatar-placeholder">
            <van-icon name="contact" size="24px" color="#FF9800" />
          </view>
          <view class="avatar-label text-sm text-gray">{{item.supervisor_name || '监督者'}}</view>
        </view>
      </view>

      <!-- Stats Row -->
      <view class="stats-row flex-between">
        <view class="stat-item text-sm">
          <text class="stat-val">{{item.checkin_days || 0}}</text>
          <text class="text-gray"> 天打卡</text>
        </view>
        <view class="stat-item text-sm">
          <text class="stat-val">{{item.total_score || 0}}</text>
          <text class="text-gray"> 积分</text>
        </view>
        <view class="stat-item text-sm text-gray">{{item.frequencyLabel}}</view>
      </view>

      <!-- Role Tag -->
      <view class="role-tag-wrap">
        <van-tag plain type="{{item.isExecutor ? 'primary' : 'warning'}}" round>{{item.roleLabel}}</van-tag>
      </view>
    </view>
  </block>
</view>
