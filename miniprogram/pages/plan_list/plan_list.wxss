/* Page Header */
.page-header {
  margin-bottom: 24rpx;
  padding: 10rpx 0;
}
.page-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #222;
}
.loading-wrap {
  padding: 120rpx 0;
  text-align: center;
}

/* Plan Card */
.plan-card {
  padding: 30rpx;
  transition: all 0.2s;
}
.plan-card:active {
  background: #f8fbff;
}
.plan-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  flex: 1;
  margin-right: 16rpx;
}

/* Avatar Pair */
.avatar-pair {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 20rpx;
  gap: 20rpx;
}
.avatar-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.pair-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid #EBF3FC;
}
.pair-avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EBF3FC 0%, #D6E8F9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-label {
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
.chain-icon {
  width: 60rpx;
  height: 60rpx;
  background: #f0f6ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Stats Row */
.stats-row {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f4f8;
}
.stat-val {
  color: #4A90D9;
  font-weight: 600;
}
.stat-item {
  display: flex;
  align-items: center;
}

/* Role Tag */
.role-tag-wrap {
  margin-top: 12rpx;
}
