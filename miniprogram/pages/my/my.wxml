<view class="page-my">
	<!-- 未登录 -->
	<block wx:if="{{!logged}}">
		<view class="not-logged">
			<view class="not-logged-bg"></view>
			<view class="not-logged-card">
				<van-icon name="friends-o" size="64px" color="#4A90D9" />
				<view class="not-logged-title">还未登录</view>
				<view class="not-logged-desc">登录后可使用笔记、签到、伙伴等功能</view>
				<van-button type="primary" round block size="large" bind:click="goLogin">立即登录</van-button>
			</view>
		</view>
	</block>

	<!-- 已登录 -->
	<block wx:if="{{logged && user}}">
		<!-- 个人信息卡 -->
		<view class="profile-card">
			<view class="profile-bg"></view>
			<view class="profile-content">
				<view class="profile-row">
					<image wx:if="{{user.avatar}}" class="profile-avatar" src="{{user.avatar}}" mode="aspectFill" />
					<view wx:else class="profile-avatar-default">
						<van-icon name="smile-o" size="32px" color="#fff" />
					</view>
					<view class="profile-info">
						<text class="profile-name">{{user.nickname || '学习者'}}</text>
						<text class="profile-bio">{{user.bio || '这个人很勤奋，什么都没留下~'}}</text>
						<text class="profile-id">ID: {{user.id}}</text>
					</view>
				</view>
			</view>
		</view>

		<!-- 个人统计 -->
		<view class="my-stats-row">
			<view class="my-stat" bindtap="goNotes">
				<view class="my-stat-num">{{myStats.noteCount || 0}}</view>
				<view class="my-stat-label">笔记</view>
			</view>
			<view class="my-stat" bindtap="goSign">
				<view class="my-stat-num">{{myStats.signDays || 0}}</view>
				<view class="my-stat-label">签到天数</view>
			</view>
			<view class="my-stat" bindtap="goPartner">
				<view class="my-stat-num">{{myStats.partnerCount || 0}}</view>
				<view class="my-stat-label">伙伴</view>
			</view>
			<view class="my-stat">
				<view class="my-stat-num">{{myStats.checkinCount || 0}}</view>
				<view class="my-stat-label">打卡</view>
			</view>
		</view>

		<!-- 功能菜单 -->
		<view class="menu-section">
			<view class="menu-group">
				<view class="menu-item" bindtap="goMessages">
					<view class="menu-icon-box" style="background:#FFF8E1;"><van-icon name="bell" color="#FF9800" size="22px" /></view>
					<text class="menu-label">消息通知</text>
					<van-tag wx:if="{{unreadCount > 0}}" type="danger" size="small" round style="margin-left:8rpx">{{unreadCount}}</van-tag>
					<view style="flex:1"></view>
					<van-icon name="arrow" color="#ccc" size="16px" />
				</view>
			</view>

			<view class="menu-group">
				<view class="menu-item" bindtap="goNotes">
					<view class="menu-icon-box" style="background:#EBF3FC;"><van-icon name="notes-o" color="#4A90D9" size="22px" /></view>
					<text class="menu-label">我的笔记</text>
					<van-icon name="arrow" color="#ccc" size="16px" />
				</view>
				<view class="menu-item" bindtap="goSign">
					<view class="menu-icon-box" style="background:#FFF3E0;"><van-icon name="clock-o" color="#FF9800" size="22px" /></view>
					<text class="menu-label">签到日历</text>
					<van-icon name="arrow" color="#ccc" size="16px" />
				</view>
				<view class="menu-item" bindtap="goPartner">
					<view class="menu-icon-box" style="background:#E8F5E9;"><van-icon name="friends-o" color="#4CAF50" size="22px" /></view>
					<text class="menu-label">学习伙伴</text>
					<van-icon name="arrow" color="#ccc" size="16px" />
				</view>
			</view>

			<view class="menu-group">
				<view class="menu-item" bindtap="goFavorite">
					<view class="menu-icon-box" style="background:#FCE4EC;"><van-icon name="star-o" color="#E91E63" size="22px" /></view>
					<text class="menu-label">我的收藏</text>
					<van-icon name="arrow" color="#ccc" size="16px" />
				</view>
				<view class="menu-item" bindtap="goEdit">
					<view class="menu-icon-box" style="background:#F3E5F5;"><van-icon name="edit" color="#9C27B0" size="22px" /></view>
					<text class="menu-label">编辑资料</text>
					<van-icon name="arrow" color="#ccc" size="16px" />
				</view>
			</view>

		</view>

		<!-- 退出按钮 -->
		<view class="logout-btn" bindtap="showLogout">退出登录</view>
	</block>

	<!-- 自定义退出确认弹窗 -->
	<view class="modal-mask" wx:if="{{showLogoutModal}}" bindtap="hideLogout">
		<view class="modal-box" catchtap="">
			<view class="modal-title">退出登录</view>
			<view class="modal-content">确定要退出当前账号吗？</view>
			<view class="modal-btns">
				<view class="modal-btn cancel" bindtap="hideLogout">取消</view>
				<view class="modal-btn confirm" bindtap="doLogout">确定退出</view>
			</view>
		</view>
	</view>
</view>
