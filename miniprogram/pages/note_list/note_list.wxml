<view class="container">
  <!-- Search Bar -->
  <view class="search-bar">
    <view class="search-wrap">
      <image class="search-icon" src="/images/icon-search.png" mode="aspectFit"></image>
      <input class="search-input" placeholder="搜索笔记..." value="{{search}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
      <view class="search-clear" wx:if="{{search}}" bindtap="onClearSearch">x</view>
    </view>
  </view>

  <!-- Tabs -->
  <view class="tabs">
    <view class="tab-item {{activeTab === index ? 'tab-active' : ''}}" wx:for="{{tabs}}" wx:key="value" data-index="{{index}}" bindtap="onTabChange">
      {{item.label}}
    </view>
  </view>

  <!-- Note List -->
  <view class="note-list" wx:if="{{notes.length > 0}}">
    <view class="card note-card" wx:for="{{notes}}" wx:key="_id" data-id="{{item._id}}" bindtap="goDetail">
      <view class="flex-between mb20">
        <view class="note-title text-bold">{{item.title}}</view>
        <view class="visibility-badge badge-{{item.visibility || 'public'}}">
          {{item.visibility === 'private' ? '私密' : item.visibility === 'partner' ? '伙伴可见' : '公开'}}
        </view>
      </view>

      <view class="note-content text-gray text-sm">{{item.content}}</view>

      <view class="tag-list mt20" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>

      <view class="flex-between mt20">
        <view class="note-stats flex">
          <view class="stat-item text-gray text-sm">
            <text class="stat-icon">&#x1F44D;</text> {{item.like_count || 0}}
          </view>
          <view class="stat-item text-gray text-sm">
            <text class="stat-icon">&#x1F4AC;</text> {{item.comment_count || 0}}
          </view>
          <view class="stat-item text-gray text-sm">
            <text class="stat-icon">&#x1F441;</text> {{item.view_count || 0}}
          </view>
        </view>
        <view class="text-gray text-sm">{{item.create_time || item.createdAt || ''}}</view>
      </view>

      <view class="card-actions flex mt20" catchtap="">
        <view class="action-btn edit-btn" catchtap="goEdit" data-id="{{item._id}}">编辑</view>
        <view class="action-btn delete-btn" catchtap="onDelete" data-id="{{item._id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- Empty State -->
  <view class="empty" wx:if="{{!loading && notes.length === 0}}">
    <view>暂无笔记</view>
    <view class="text-sm mt20 text-gray">点击右下角按钮创建第一篇笔记吧</view>
  </view>

  <!-- Loading -->
  <view class="loading-tip text-gray text-sm" wx:if="{{loading}}">加载中...</view>
  <view class="loading-tip text-gray text-sm" wx:if="{{!hasMore && notes.length > 0}}">没有更多了</view>

  <!-- FAB Button -->
  <view class="fab" bindtap="goCreate">+</view>
</view>
