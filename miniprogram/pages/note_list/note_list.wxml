<view class="container">
  <!-- Search Bar -->
  <view class="search-bar">
    <view class="search-wrap">
      <van-icon name="search" size="16px" color="#999" />
      <input class="search-input" placeholder="搜索笔记..." value="{{search}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
      <view class="search-clear" wx:if="{{search}}" bindtap="onClearSearch">
        <van-icon name="cross" size="14px" color="#999" />
      </view>
    </view>
  </view>

  <!-- Tabs -->
  <view class="tabs">
    <view class="tab-item {{activeTab === index ? 'tab-active' : ''}}" wx:for="{{tabs}}" wx:key="value" data-index="{{index}}" bindtap="onTabChange">
      {{item.label}}
    </view>
  </view>

  <!-- Note List -->
  <view class="note-list" wx:if="{{notes.length > 0}}">
    <view class="card note-card" wx:for="{{notes}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="flex-between mb20">
        <view class="note-title text-bold">{{item.title}}</view>
        <view class="visibility-badge badge-{{item.visibility || 'public'}}">
          {{item.visibility === 'private' ? '私密' : item.visibility === 'partner' ? '伙伴可见' : '公开'}}
        </view>
      </view>

      <view class="note-content text-gray text-sm">{{item.content}}</view>

      <view class="tag-list mt20" wx:if="{{item.tags && item.tags.length > 0}}">
        <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
      </view>

      <view class="flex-between mt20">
        <view class="note-stats flex">
          <view class="stat-item text-gray text-sm">
            <van-icon name="good-job-o" size="14px" color="#999" /> {{item.like_cnt || 0}}
          </view>
          <view class="stat-item text-gray text-sm">
            <van-icon name="chat-o" size="14px" color="#999" /> {{item.comment_cnt || 0}}
          </view>
          <view class="stat-item text-gray text-sm">
            <van-icon name="eye-o" size="14px" color="#999" /> {{item.view_cnt || 0}}
          </view>
        </view>
        <view class="text-gray text-sm">{{item.created_at || ''}}</view>
      </view>

      <view class="card-actions flex mt20" catchtap="">
        <view class="action-btn edit-btn" catchtap="goEdit" data-id="{{item.id}}">
          <van-icon name="edit" size="14px" /> 编辑
        </view>
        <view class="action-btn delete-btn" catchtap="onDelete" data-id="{{item.id}}">
          <van-icon name="cross" size="14px" /> 删除
        </view>
      </view>
    </view>
  </view>

  <!-- Empty State -->
  <van-empty wx:if="{{!loading && notes.length === 0}}" description="暂无笔记，点击右下角按钮创建第一篇笔记吧" />

  <!-- Loading -->
  <van-loading wx:if="{{loading}}" size="24px" vertical>加载中...</van-loading>
  <van-divider wx:if="{{!hasMore && notes.length > 0}}" contentPosition="center">没有更多了</van-divider>

  <!-- FAB Button -->
  <view class="fab" bindtap="goCreate">
    <van-icon name="plus" size="24px" color="#fff" />
  </view>
</view>
