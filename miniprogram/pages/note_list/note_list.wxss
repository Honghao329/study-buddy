.search-bar {
  padding: 10rpx 0 20rpx;
}
.search-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.4;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
}
.search-clear {
  color: #999;
  font-size: 28rpx;
  padding: 0 10rpx;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}
.tab-active {
  color: #4A90D9;
  font-weight: bold;
}
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #4A90D9;
  border-radius: 2rpx;
}

.note-card {
  position: relative;
}
.note-title {
  font-size: 30rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}
.note-content {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.6;
}
.visibility-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}
.badge-public {
  background: #e8f5e9;
  color: #43a047;
}
.badge-private {
  background: #fce4ec;
  color: #e91e63;
}
.badge-partner {
  background: #e3f2fd;
  color: #4A90D9;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
}

.note-stats {
  display: flex;
  gap: 24rpx;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.card-actions {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  gap: 20rpx;
}
.action-btn {
  font-size: 24rpx;
  padding: 8rpx 28rpx;
  border-radius: 24rpx;
}
.edit-btn {
  background: #e3f2fd;
  color: #4A90D9;
}
.delete-btn {
  background: #fce4ec;
  color: #e91e63;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  box-shadow: 0 6rpx 20rpx rgba(74,144,217,0.4);
  z-index: 99;
}
