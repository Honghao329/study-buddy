<view class="page" wx:if="{{detail}}">
	<!-- ① 任务头部 -->
	<view class="hero">
		<view class="hero-badge" wx:if="{{detail.is_supervisor}}">你是监督者</view>
		<view class="hero-badge participant" wx:elif="{{detail.my_total > 0}}">你已参与</view>
		<view class="hero-title">{{detail.title}}</view>
		<view class="hero-desc" wx:if="{{detail.description}}">{{detail.description}}</view>
		<view class="hero-date" wx:if="{{detail.start_date}}">
			<van-icon name="clock-o" size="12px" color="rgba(255,255,255,0.6)" />
			<text>{{detail.start_date}} ~ {{detail.end_date}}</text>
		</view>
	</view>

	<!-- ② 数据卡片（浮起） -->
	<view class="data-row">
		<view class="data-item">
			<view class="data-num accent">{{detail.my_total || 0}}</view>
			<view class="data-label">我的打卡</view>
		</view>
		<view class="data-sep"></view>
		<view class="data-item">
			<view class="data-num">{{detail.join_cnt || 0}}</view>
			<view class="data-label">总参与</view>
		</view>
		<view class="data-sep"></view>
		<view class="data-item">
			<view class="data-num">{{detail.view_cnt || 0}}</view>
			<view class="data-label">浏览</view>
		</view>
	</view>

	<!-- ③ 监督关系（最重要的社交信息，用大白话说清楚） -->
	<view class="card">
		<view class="card-title">监督关系</view>

		<!-- 有监督者 -->
		<view wx:if="{{detail.has_supervisor}}" class="buddy-card">
			<image class="buddy-avatar" src="{{detail.supervisor_avatar}}" mode="aspectFill" />
			<view class="buddy-info">
				<text class="buddy-name">{{detail.supervisor_display_name || '监督者'}}</text>
				<text class="buddy-desc" wx:if="{{detail.is_supervisor}}">你正在监督这个任务，可以评价和催打卡</text>
				<text class="buddy-desc" wx:else>{{detail.supervisor_display_name}} 正在监督你完成这个任务</text>
			</view>
		</view>

		<!-- 监督者工具 -->
		<view wx:if="{{detail.is_supervisor}}" class="buddy-actions">
			<view class="action-btn warn" bindtap="remindCheckin">
				<van-icon name="bell" size="16px" /> 催打卡
			</view>
		</view>

		<!-- 没有监督者 -->
		<view wx:if="{{!detail.has_supervisor}}" class="invite-row" bindtap="openInvite">
			<view class="invite-icon">
				<van-icon name="friends-o" size="20px" color="#4A90D9" />
			</view>
			<view class="invite-info">
				<text class="invite-title">邀请伙伴监督</text>
				<text class="invite-sub">有人监督，坚持更容易</text>
			</view>
			<van-icon name="arrow" size="14px" color="#ccc" />
		</view>
	</view>

	<!-- ④ 参与者头像（简洁横排） -->
	<view class="card" wx:if="{{detail.recent_users && detail.recent_users.length > 0}}">
		<view class="card-title">参与者 ({{detail.join_cnt || detail.recent_users.length}})</view>
		<scroll-view scroll-x class="people-scroll">
			<view class="people-item" wx:for="{{detail.recent_users}}" wx:key="nickname">
				<image class="people-avatar" src="{{item.avatar}}" mode="aspectFill" />
				<text class="people-name">{{item.nickname || '用户'}}</text>
			</view>
		</scroll-view>
	</view>

	<!-- ⑤ 打卡记录（卡片列表，不用时间线） -->
	<view class="card">
		<view class="card-header">
			<text class="card-title">打卡记录</text>
			<text class="card-count">{{recordTotal || 0}} 条</text>
		</view>

		<van-empty wx:if="{{records.length === 0}}" description="还没有人打卡，成为第一个吧" />

		<view class="record-list" wx:if="{{records.length > 0}}">
			<view class="record-item" wx:for="{{records}}" wx:key="id">
				<!-- 记录头：谁 + 什么时候 -->
				<view class="record-top">
					<image class="record-avatar" src="{{item.user_avatar}}" mode="aspectFill" />
					<view class="record-meta">
						<text class="record-name">{{item.user_name || '用户'}}</text>
						<text class="record-date">{{item.day}}</text>
					</view>
				</view>

				<!-- 记录内容 -->
				<view class="record-body" wx:if="{{item.content}}">{{item.content}}</view>
				<view class="record-body muted" wx:else>完成了打卡 ✓</view>

				<!-- 监督评价（如果有） -->
				<view wx:if="{{item.comment}}" class="review-box">
					<view class="review-header">
						<van-icon name="comment-o" size="14px" color="#4A90D9" />
						<text class="review-label">监督评价</text>
						<van-rate value="{{item.score}}" size="12" color="#ffd21e" void-color="#eee" readonly />
					</view>
					<text class="review-text">{{item.comment}}</text>
				</view>

				<!-- 监督者可评价按钮 -->
				<view wx:if="{{detail.is_supervisor && !item.comment}}" class="record-action">
					<view class="action-btn small" data-id="{{item.id}}" bindtap="openComment">
						<van-icon name="edit" size="13px" /> 写评价
					</view>
				</view>
			</view>
		</view>
	</view>

	<van-loading wx:if="{{loadingRecords}}" size="24px" vertical>加载中...</van-loading>
	<van-divider wx:if="{{!hasMoreRecords && records.length > 0}}" contentPosition="center">没有更多了</van-divider>

	<!-- 底部占位 -->
	<view style="height: 160rpx;"></view>

	<!-- ⑥ 底部固定栏 -->
	<view class="bottom-bar">
		<button class="share-circle" open-type="share">
			<van-icon name="share-o" size="18px" color="#4A90D9" />
		</button>
		<view style="flex:1">
			<van-button wx:if="{{detail.is_joined}}" block round size="large" disabled icon="checked">今日已打卡</van-button>
			<van-button wx:else block round size="large" type="primary" icon="edit" bind:click="openCheckinForm">立即打卡</van-button>
		</view>
	</view>

	<!-- 弹窗：打卡 -->
	<van-popup show="{{showCheckinForm}}" position="bottom" round bind:close="closeCheckinForm" safe-area-inset-bottom>
		<view class="popup-content">
			<view class="popup-title">今日打卡</view>
			<view class="form-group">
				<text class="form-label">记录今天的学习内容（选填）</text>
				<textarea class="form-textarea" placeholder="比如：今天背了50个单词..." value="{{checkinContent}}" bindinput="onCheckinContentInput" maxlength="500" auto-height />
			</view>
			<van-button type="primary" block round bind:click="onJoin" loading="{{joining}}" custom-style="margin-top:24rpx">提交打卡</van-button>
		</view>
	</van-popup>

	<!-- 弹窗：邀请监督 -->
	<van-popup show="{{showInvite}}" position="bottom" round bind:close="closeInvite">
		<view class="popup-content">
			<view class="popup-title">选择伙伴作为监督者</view>
			<view wx:if="{{partners.length === 0}}" class="popup-empty">
				<text>暂无伙伴</text>
				<van-button size="small" type="primary" plain round custom-style="margin-top:16rpx" bind:click="goPartner">去发现伙伴</van-button>
			</view>
			<view class="partner-option" wx:for="{{partners}}" wx:key="id" data-id="{{item.id}}" bindtap="selectSupervisor">
				<view class="partner-dot"></view>
				<text class="partner-name">{{item.name}}</text>
				<van-icon name="arrow" size="16px" color="#ccc" />
			</view>
		</view>
	</van-popup>

	<!-- 弹窗：评价 -->
	<van-popup show="{{showComment}}" position="bottom" round bind:close="closeComment">
		<view class="popup-content">
			<view class="popup-title">评价打卡记录</view>
			<view class="form-group">
				<text class="form-label">评分</text>
				<van-rate value="{{commentScore}}" bind:change="onScoreChange" size="28px" color="#ffd21e" void-icon="star" void-color="#eee" />
			</view>
			<view class="form-group">
				<text class="form-label">评语</text>
				<textarea class="form-textarea" placeholder="写点评语鼓励一下..." value="{{commentText}}" bindinput="onCommentInput" maxlength="200" auto-height />
			</view>
			<van-button type="primary" block round bind:click="submitComment" custom-style="margin-top:24rpx">提交评价</van-button>
		</view>
	</van-popup>
</view>

<view class="loading-page" wx:if="{{!detail && !detailFailed}}">
	<van-loading size="24px" vertical>加载中...</van-loading>
</view>
<view class="loading-page" wx:if="{{!detail && detailFailed}}">
	<van-empty description="加载失败，请下拉重试" image="error" />
</view>
