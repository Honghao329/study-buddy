<view class="page" wx:if="{{detail}}">
	<!-- 头部 -->
	<view class="header-card">
		<view class="header-title">{{detail.title}}</view>
		<view class="header-desc" wx:if="{{detail.description}}">{{detail.description}}</view>
		<view class="header-meta" wx:if="{{detail.start_date}}">
			<van-icon name="clock-o" size="14px" color="rgba(255,255,255,0.7)" />
			<text>{{detail.start_date}} ~ {{detail.end_date}}</text>
		</view>
	</view>

	<!-- 统计卡片 -->
	<view class="stats-card">
		<view class="stat-block">
			<view class="stat-num">{{detail.join_cnt || 0}}</view>
			<view class="stat-label">参与人次</view>
		</view>
		<view class="stat-divider"></view>
		<view class="stat-block">
			<view class="stat-num highlight">{{detail.my_total || 0}}</view>
			<view class="stat-label">我的打卡</view>
		</view>
		<view class="stat-divider"></view>
		<view class="stat-block">
			<view class="stat-num">{{detail.view_cnt || 0}}</view>
			<view class="stat-label">浏览量</view>
		</view>
	</view>

	<!-- 监督者信息（独立区块） -->
	<view class="section">
		<view class="section-header">
			<text class="section-title">伙伴监督</text>
			<van-tag wx:if="{{detail.is_supervisor}}" type="warning" size="medium">你是监督者</van-tag>
		</view>

		<view wx:if="{{detail.has_supervisor}}" class="supervisor-card">
			<view class="supervisor-info">
				<image wx:if="{{detail.supervisor_avatar}}" class="supervisor-avatar" src="{{detail.supervisor_avatar}}" mode="aspectFill" />
				<view wx:else class="avatar-circle small">
					<van-icon name="smile-o" size="18px" color="#fff" />
				</view>
				<view class="supervisor-text">
					<text class="supervisor-name">{{detail.supervisor_display_name || '监督者'}}</text>
					<text class="supervisor-role">{{detail.is_supervisor ? '你正在监督此任务' : '正在监督中'}}</text>
				</view>
			</view>
			<van-tag type="success" size="medium">已邀请</van-tag>
		</view>
		<view wx:else class="invite-card" bindtap="openInvite">
			<van-icon name="friends-o" size="24px" color="#4A90D9" />
			<text class="invite-text">邀请伙伴来监督</text>
			<van-icon name="arrow" size="16px" color="#ccc" />
		</view>

		<!-- 监督者工具栏 -->
		<view wx:if="{{detail.is_supervisor}}" class="supervisor-tools">
			<van-button size="small" plain type="warning" icon="bell" bind:click="remindCheckin" custom-style="flex:1">催打卡</van-button>
		</view>
	</view>

	<!-- 最近参与者 -->
	<view class="section" wx:if="{{detail.recent_users && detail.recent_users.length > 0}}">
		<text class="section-title">最近参与</text>
		<scroll-view scroll-x class="avatar-scroll">
			<view class="avatar-item" wx:for="{{detail.recent_users}}" wx:key="nickname">
				<image wx:if="{{item.avatar}}" class="avatar-small-img" src="{{item.avatar}}" mode="aspectFill" />
				<view wx:else class="avatar-circle small"><van-icon name="smile-o" size="16px" color="#fff" /></view>
				<text class="avatar-name">{{item.nickname || '用户'}}</text>
			</view>
		</scroll-view>
	</view>

	<!-- 打卡记录时间线 -->
	<view class="section">
		<view class="section-header">
			<text class="section-title">打卡记录</text>
			<text class="section-sub">共 {{recordTotal || 0}} 条</text>
		</view>

		<van-empty wx:if="{{records.length === 0}}" description="暂无打卡记录，快来第一个打卡吧" />

		<view class="timeline" wx:if="{{records.length > 0}}">
			<view class="timeline-item" wx:for="{{records}}" wx:key="id">
				<view class="timeline-dot"></view>
				<view class="timeline-card">
					<view class="timeline-header">
						<view class="timeline-user">
							<image wx:if="{{item.user_avatar}}" class="timeline-avatar" src="{{item.user_avatar}}" mode="aspectFill" />
							<view wx:else class="avatar-circle tiny"><van-icon name="smile-o" size="12px" color="#fff" /></view>
							<text class="timeline-name">{{item.user_name || '用户'}}</text>
						</view>
						<text class="timeline-day">{{item.day}}</text>
					</view>
					<view class="timeline-content" wx:if="{{item.content}}">{{item.content}}</view>
					<view class="timeline-content empty" wx:else>已完成打卡</view>

					<!-- 已评价 -->
					<view wx:if="{{item.comment}}" class="comment-box">
						<view class="comment-header">
							<van-icon name="chat-o" size="14px" color="#4A90D9" />
							<text class="comment-label">监督评价</text>
							<van-rate value="{{item.score}}" size="12" color="#ffd21e" void-color="#eee" readonly />
						</view>
						<text class="comment-text">{{item.comment}}</text>
					</view>

					<!-- 监督者可评价 -->
					<view wx:if="{{detail.is_supervisor && !item.comment}}" class="timeline-actions">
						<van-button size="small" plain type="primary" icon="edit" data-id="{{item.id}}" bind:click="openComment">写评价</van-button>
					</view>
				</view>
			</view>
		</view>
	</view>

	<!-- 底部空白占位 -->
	<view style="height: 140rpx;"></view>

	<!-- 底部固定操作栏 — 打卡和监督完全分离 -->
	<view class="bottom-bar">
		<van-button wx:if="{{detail.is_joined}}" block round size="large" disabled icon="checked" custom-style="flex:1">今日已打卡</van-button>
		<van-button wx:else block round size="large" type="primary" icon="edit" bind:click="openCheckinForm" custom-style="flex:1">打卡</van-button>
	</view>

	<button class="share-btn" open-type="share">
		<van-icon name="share-o" size="14px" /> 分享给好友
	</button>

	<!-- 打卡填写弹窗 -->
	<van-popup show="{{showCheckinForm}}" position="bottom" round bind:close="closeCheckinForm" safe-area-inset-bottom>
		<view class="popup-content">
			<view class="popup-title">今日打卡</view>
			<view class="form-group">
				<text class="form-label">记录今天的学习内容（选填）</text>
				<textarea class="checkin-textarea" placeholder="比如：今天背了50个单词..." value="{{checkinContent}}" bindinput="onCheckinContentInput" maxlength="500" auto-height />
			</view>
			<van-button type="primary" block round bind:click="onJoin" loading="{{joining}}" custom-style="margin-top:24rpx">提交打卡</van-button>
		</view>
	</van-popup>

	<!-- 邀请监督弹窗 -->
	<van-popup show="{{showInvite}}" position="bottom" round bind:close="closeInvite">
		<view class="popup-content">
			<view class="popup-title">选择伙伴作为监督者</view>
			<view wx:if="{{partners.length === 0}}" class="popup-empty">
				<text>暂无伙伴</text>
				<van-button size="small" type="primary" plain round custom-style="margin-top:16rpx" bind:click="goPartner">去发现伙伴</van-button>
			</view>
			<view class="partner-option" wx:for="{{partners}}" wx:key="id" data-id="{{item.id}}" bindtap="selectSupervisor">
				<view class="avatar-circle small"><van-icon name="smile-o" size="16px" color="#fff" /></view>
				<text class="partner-name">{{item.name}}</text>
				<van-icon name="arrow" size="16px" color="#ccc" />
			</view>
		</view>
	</van-popup>

	<!-- 评价弹窗 -->
	<van-popup show="{{showComment}}" position="bottom" round bind:close="closeComment">
		<view class="popup-content">
			<view class="popup-title">评价打卡记录</view>
			<view class="form-group">
				<text class="form-label">评分</text>
				<van-rate value="{{commentScore}}" bind:change="onScoreChange" size="28px" color="#ffd21e" void-icon="star" void-color="#eee" />
			</view>
			<view class="form-group">
				<text class="form-label">评语</text>
				<textarea class="checkin-textarea" placeholder="写点评语鼓励一下..." value="{{commentText}}" bindinput="onCommentInput" maxlength="200" auto-height />
			</view>
			<van-button type="primary" block round bind:click="submitComment" custom-style="margin-top:24rpx">提交评价</van-button>
		</view>
	</van-popup>
</view>

<view class="loading-page" wx:if="{{!detail}}">
	<van-loading size="24px" vertical>加载中...</van-loading>
</view>
