.page { min-height: 100vh; background: #f5f6fa; padding-bottom: 180rpx; }

/* ===== ① Hero 头部 ===== */
.hero {
	background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
	padding: 48rpx 36rpx 56rpx; color: #fff;
	border-radius: 0 0 32rpx 32rpx;
	position: relative;
}
.hero-badge {
	display: inline-block; font-size: 22rpx; font-weight: 500;
	background: rgba(255,255,255,0.2); color: #fff;
	padding: 6rpx 18rpx; border-radius: 20rpx; margin-bottom: 16rpx;
}
.hero-badge.participant { background: rgba(76,175,80,0.3); }
.hero-title { font-size: 38rpx; font-weight: bold; line-height: 1.4; margin-bottom: 10rpx; }
.hero-desc { font-size: 26rpx; opacity: 0.8; line-height: 1.6; margin-bottom: 10rpx; }
.hero-date { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; opacity: 0.6; }

/* ===== ② 数据卡片 ===== */
.data-row {
	display: flex; background: #fff; margin: -28rpx 28rpx 0;
	border-radius: 16rpx; padding: 24rpx 0;
	box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
	position: relative; z-index: 2;
}
.data-item { flex: 1; text-align: center; }
.data-num { font-size: 40rpx; font-weight: bold; color: #333; line-height: 1.2; }
.data-num.accent { color: #4A90D9; }
.data-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.data-sep { width: 1rpx; background: #f0f0f0; margin: 6rpx 0; }

/* ===== 通用 Card ===== */
.card {
	margin: 20rpx 28rpx 0; background: #fff;
	border-radius: 16rpx; padding: 24rpx 28rpx;
	box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.card-title { font-size: 28rpx; font-weight: 600; color: #333; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.card-count { font-size: 24rpx; color: #999; }

/* ===== ③ 监督关系 ===== */
.buddy-card {
	display: flex; align-items: center; gap: 16rpx;
	margin-top: 16rpx; padding: 16rpx 20rpx;
	background: #f0f7ff; border-radius: 12rpx;
}
.buddy-avatar {
	width: 64rpx; height: 64rpx; border-radius: 50%; flex-shrink: 0;
	border: 3rpx solid #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.buddy-info { flex: 1; min-width: 0; }
.buddy-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.buddy-desc { font-size: 22rpx; color: #4A90D9; display: block; margin-top: 4rpx; line-height: 1.5; }

.buddy-actions {
	display: flex; gap: 12rpx; margin-top: 16rpx;
	padding-top: 16rpx; border-top: 1rpx solid #f0f0f0;
}

.action-btn {
	display: flex; align-items: center; gap: 6rpx; justify-content: center;
	font-size: 24rpx; padding: 12rpx 24rpx; border-radius: 24rpx;
	background: #f0f7ff; color: #4A90D9; flex: 1;
}
.action-btn.warn { background: #fff7ed; color: #f59e0b; }
.action-btn.small { flex: none; font-size: 22rpx; padding: 8rpx 20rpx; background: #f5f6fa; color: #666; }

/* 邀请监督 */
.invite-row {
	display: flex; align-items: center; gap: 16rpx;
	margin-top: 16rpx; padding: 16rpx 0;
}
.invite-icon {
	width: 48rpx; height: 48rpx; border-radius: 50%;
	background: #f0f7ff; display: flex; align-items: center; justify-content: center;
	flex-shrink: 0;
}
.invite-info { flex: 1; }
.invite-title { font-size: 28rpx; color: #333; font-weight: 500; display: block; }
.invite-sub { font-size: 22rpx; color: #999; display: block; margin-top: 2rpx; }

/* ===== ④ 参与者 ===== */
.people-scroll { white-space: nowrap; padding: 12rpx 0 4rpx; }
.people-item {
	display: inline-flex; flex-direction: column; align-items: center;
	margin-right: 24rpx; width: 80rpx;
}
.people-avatar {
	width: 56rpx; height: 56rpx; border-radius: 50%; margin-bottom: 6rpx;
	border: 2rpx solid #f0f0f0;
}
.people-name {
	font-size: 20rpx; color: #666; overflow: hidden;
	text-overflow: ellipsis; white-space: nowrap; max-width: 80rpx;
}

/* ===== ⑤ 打卡记录 ===== */
.record-list { margin-top: 8rpx; }
.record-item {
	padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.record-item:last-child { border-bottom: none; }

.record-top { display: flex; align-items: center; gap: 12rpx; }
.record-avatar {
	width: 48rpx; height: 48rpx; border-radius: 50%; flex-shrink: 0;
	border: 2rpx solid #f0f0f0;
}
.record-meta { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.record-name { font-size: 26rpx; font-weight: 600; color: #333; }
.record-date { font-size: 22rpx; color: #bbb; }

.record-body {
	font-size: 26rpx; color: #555; line-height: 1.6;
	margin-top: 10rpx; padding-left: 60rpx;
}
.record-body.muted { color: #ccc; font-size: 24rpx; }

.record-action { padding-left: 60rpx; margin-top: 10rpx; }

/* 监督评价 */
.review-box {
	margin: 12rpx 0 0 60rpx; padding: 14rpx 18rpx;
	background: #f8fafe; border-radius: 10rpx;
	border-left: 4rpx solid #4A90D9;
}
.review-header { display: flex; align-items: center; gap: 8rpx; margin-bottom: 6rpx; }
.review-label { font-size: 22rpx; color: #4A90D9; font-weight: 500; }
.review-text { font-size: 24rpx; color: #555; line-height: 1.5; display: block; }

/* ===== ⑥ 底部栏 ===== */
.bottom-bar {
	position: fixed; bottom: 0; left: 0; right: 0;
	padding: 16rpx 28rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
	background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
	z-index: 10; display: flex; gap: 16rpx; align-items: center;
}
.share-circle {
	width: 76rpx; height: 76rpx; border-radius: 50%; flex-shrink: 0;
	background: #f0f7ff; border: none; padding: 0;
	display: flex; align-items: center; justify-content: center;
	line-height: 1;
}
.share-circle::after { border: none; }

/* ===== 弹窗 ===== */
.popup-content { padding: 36rpx; }
.popup-title { font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 28rpx; }
.popup-empty { text-align: center; color: #999; padding: 40rpx 0; }
.form-group { margin-bottom: 20rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; display: block; }
.form-textarea {
	width: 100%; box-sizing: border-box;
	border: 2rpx solid #e8eef6; border-radius: 12rpx;
	padding: 20rpx; font-size: 28rpx; background: #f8fbff;
	min-height: 120rpx; line-height: 1.5;
}
.partner-option {
	display: flex; align-items: center; gap: 16rpx;
	padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.partner-dot {
	width: 36rpx; height: 36rpx; border-radius: 50%;
	background: linear-gradient(135deg, #4A90D9, #6BB5F0);
}
.partner-name { flex: 1; font-size: 28rpx; color: #333; }

/* ===== 加载态 ===== */
.loading-page { display: flex; justify-content: center; align-items: center; min-height: 60vh; }
