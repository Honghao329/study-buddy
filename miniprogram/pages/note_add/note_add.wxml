<view class="container">
  <!-- Title -->
  <view class="form-group">
    <view class="form-label text-bold">标题</view>
    <input class="input" placeholder="请输入笔记标题" value="{{title}}" bindinput="onTitleInput" maxlength="50" />
  </view>

  <!-- Content -->
  <view class="form-group">
    <view class="form-label text-bold">内容</view>
    <textarea class="input textarea" placeholder="请输入笔记内容..." value="{{content}}" bindinput="onContentInput" maxlength="5000" auto-height="{{false}}" />
  </view>

  <!-- Visibility -->
  <view class="form-group">
    <view class="form-label text-bold">可见性</view>
    <picker mode="selector" range="{{visibilityOptions}}" value="{{visibilityIndex}}" bindchange="onVisibilityChange">
      <view class="input picker-value flex-between">
        <text>{{visibilityOptions[visibilityIndex]}}</text>
        <text class="text-gray">&#x25BC;</text>
      </view>
    </picker>
  </view>

  <!-- Tags -->
  <view class="form-group">
    <view class="form-label text-bold">标签</view>
    <view class="tag-input-wrap">
      <input class="input tag-input" placeholder="输入标签后点击添加" value="{{tagInput}}" bindinput="onTagInput" bindconfirm="addTag" />
      <view class="tag-add-btn" bindtap="addTag">添加</view>
    </view>
    <view class="tag-list mt20" wx:if="{{tags.length > 0}}">
      <view class="tag tag-removable" wx:for="{{tags}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="tag-remove" data-index="{{index}}" catchtap="removeTag"> x</text>
      </view>
    </view>
  </view>

  <!-- Images -->
  <view class="form-group">
    <view class="form-label text-bold">图片</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image class="preview-img" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewImage" />
        <view class="image-remove" data-index="{{index}}" catchtap="removeImage">x</view>
      </view>
      <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < 9}}">
        <text class="add-icon">+</text>
        <text class="text-gray text-sm">添加图片</text>
      </view>
    </view>
  </view>

  <!-- Submit -->
  <view class="btn-primary submit-btn" bindtap="onSubmit">
    {{submitting ? '提交中...' : (isEdit ? '更新笔记' : '发布笔记')}}
  </view>
</view>
