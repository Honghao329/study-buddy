.msg-toolbar { display: flex; justify-content: space-between; align-items: center; padding: 0 30rpx 16rpx; }
.msg-count { font-size: 24rpx; color: #999; }
.read-all-btn { font-size: 24rpx; color: #4A90D9; }

.msg-item {
	display: flex; align-items: flex-start; gap: 20rpx;
	padding: 24rpx; margin-bottom: 12rpx; position: relative;
}
.msg-item.unread { background: #f0f7ff; }
.msg-icon-wrap {
	width: 64rpx; height: 64rpx; border-radius: 50%;
	display: flex; align-items: center; justify-content: center;
	flex-shrink: 0;
}
.msg-icon-wrap.remind { background: #FFF3E0; }
.msg-icon-wrap.like { background: #FFEBEE; }
.msg-icon-wrap.comment { background: #EBF3FC; }
.msg-icon-wrap.partner { background: #E8F5E9; }
.msg-icon-wrap.system { background: #f5f6fa; }
.msg-body { flex: 1; }
.msg-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.msg-content { font-size: 26rpx; color: #666; line-height: 1.5; margin-bottom: 6rpx; }
.msg-time { font-size: 22rpx; }
.msg-dot {
	width: 16rpx; height: 16rpx; border-radius: 50%;
	background: #f56c6c; position: absolute; top: 28rpx; right: 24rpx;
}
