.author-card {
  display: flex;
}
.author-info {
  margin-left: 16rpx;
}
.visibility-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  height: fit-content;
}
.badge-public { background: #e8f5e9; color: #43a047; }
.badge-private { background: #fce4ec; color: #e91e63; }
.badge-partner { background: #e3f2fd; color: #4A90D9; }

.note-title {
  font-size: 36rpx;
  line-height: 1.4;
}
.note-body {
  font-size: 30rpx;
  line-height: 1.8;
  color: #444;
  white-space: pre-wrap;
  word-break: break-all;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.note-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.action-bar {
  display: flex;
  justify-content: space-around;
}
.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 0;
}
.action-active {
  color: #e91e63;
}
.action-text {
  font-size: 24rpx;
}

.section-title {
  font-size: 30rpx;
  padding: 20rpx 0 10rpx;
}

.comment-card {
  padding: 24rpx 30rpx;
}
.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}
.comment-meta {
  margin-left: 16rpx;
}
.comment-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
  padding-left: 80rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}

.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.04);
  z-index: 100;
}
.comment-input {
  flex: 1;
  background: #f5f6fa;
  border-radius: 32rpx;
  padding: 14rpx 24rpx;
  font-size: 28rpx;
  height: 44rpx;
}
.send-btn {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #ccc;
  padding: 10rpx 24rpx;
  white-space: nowrap;
}
.send-active {
  color: #4A90D9;
  font-weight: bold;
}
