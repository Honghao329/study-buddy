/* Author Card */
.author-card {
  display: flex;
  background: linear-gradient(135deg, #f8fbff 0%, #fff 100%);
}
.author-info {
  margin-left: 16rpx;
}
.avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8EEF6 0%, #D6E8F9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.visibility-badge {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  height: fit-content;
  font-weight: 500;
}
.badge-public { background: #E8F5E9; color: #43a047; }
.badge-private { background: #FCE4EC; color: #e91e63; }
.badge-partner { background: #E3F2FD; color: #4A90D9; }

/* Note Content */
.content-card {
  border-top: 4rpx solid #4A90D9;
}
.note-title {
  font-size: 38rpx;
  line-height: 1.4;
  color: #222;
}
.note-body {
  font-size: 30rpx;
  line-height: 1.9;
  color: #444;
  white-space: pre-wrap;
  word-break: break-all;
}

/* Images */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.note-image {
  width: 210rpx;
  height: 210rpx;
  border-radius: 16rpx;
}

/* Tags */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

/* Action Bar */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx;
}
.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
  transition: all 0.2s;
}
.action-item:active {
  background: #f5f6fa;
}
.action-active {
  color: #e91e63;
}
.action-text {
  font-size: 24rpx;
}

/* Comments */
.section-title {
  font-size: 30rpx;
  padding: 24rpx 0 12rpx;
}

.comment-card {
  padding: 28rpx 30rpx;
  border-left: 4rpx solid #EBF3FC;
}
.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.comment-avatar-ph {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex; align-items: center; justify-content: center;
}
.comment-avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8EEF6 0%, #D6E8F9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.comment-meta {
  margin-left: 16rpx;
}
.comment-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
  padding-left: 80rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}

/* Comment Input Bar */
.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.comment-input {
  flex: 1;
  background: #f5f6fa;
  border-radius: 32rpx;
  padding: 14rpx 24rpx;
  font-size: 28rpx;
  height: 44rpx;
  line-height: 44rpx;
}
.send-btn {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #ccc;
  padding: 10rpx 24rpx;
  white-space: nowrap;
  border-radius: 24rpx;
  transition: all 0.2s;
}
.send-active {
  color: #fff;
  background: #4A90D9;
  font-weight: bold;
}
