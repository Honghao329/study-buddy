.feed-list { padding: 0 0 20rpx; }
.feed-card { margin: 20rpx 0; padding: 28rpx; }
.feed-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.feed-author-row { display: flex; align-items: center; flex: 1; }
.feed-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; }
.feed-author-info { flex: 1; margin-left: 16rpx; }
.feed-follow-btn {
	display: flex; align-items: center; gap: 4rpx;
	font-size: 22rpx; color: #4A90D9;
	border: 1rpx solid #4A90D9; border-radius: 24rpx;
	padding: 6rpx 16rpx; white-space: nowrap;
}
.feed-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.feed-time { display: block; margin-top: 4rpx; }
.feed-title { font-size: 32rpx; font-weight: bold; color: #333; display: block; margin-bottom: 12rpx; }
.feed-text { font-size: 28rpx; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.feed-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.feed-actions { display: flex; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.feed-action { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx; }
.action-num { font-size: 24rpx; color: #999; }
