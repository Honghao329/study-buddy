.search-bar {
  padding: 10rpx 0 20rpx;
}
.search-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.4;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 48rpx;
}
.search-clear {
  color: #999;
  font-size: 28rpx;
  padding: 0 10rpx;
}

.sort-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.sort-tab {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  background: #fff;
}
.sort-active {
  color: #fff;
  background: #4A90D9;
  font-weight: bold;
}

.feed-card {
  position: relative;
}
.feed-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}
.feed-author {
  margin-left: 16rpx;
}
.feed-title {
  font-size: 32rpx;
  line-height: 1.4;
}
.feed-content {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  line-height: 1.6;
  font-size: 28rpx;
}

.feed-images {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.feed-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}
.more-images {
  background: #f5f6fa;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.feed-footer {
  border-top: 1rpx solid #f5f5f5;
  padding-top: 16rpx;
}
.feed-stats {
  display: flex;
  gap: 32rpx;
}
.stat-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.loading-tip {
  text-align: center;
  padding: 30rpx 0;
}
