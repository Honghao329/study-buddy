<view class="container">
	<van-search value="{{search}}" placeholder="搜索社区笔记" bind:search="onSearch" bind:change="onSearchInput" bind:clear="onClearSearch" shape="round" />

	<van-tabs active="{{sortIndex}}" bind:change="onSortChange" color="#4A90D9" title-active-color="#4A90D9">
		<van-tab title="最新"></van-tab>
		<van-tab title="最热"></van-tab>
	</van-tabs>

	<view class="feed-list">
		<view class="card feed-card" wx:for="{{notes}}" wx:key="id">
			<view class="feed-header">
				<view class="feed-author-row" catchtap="goProfile" data-uid="{{item.user_id}}">
					<image wx:if="{{item.user_pic}}" class="feed-avatar" src="{{item.user_pic}}" mode="aspectFill" binderror="onAvatarError" data-idx="{{index}}" />
					<view wx:else class="feed-avatar-default">
						<van-icon name="smile-o" size="22px" color="#fff" />
					</view>
					<view class="feed-author-info">
						<text class="feed-name">{{item.user_name || '匿名'}}</text>
						<text class="feed-time text-sm text-gray">{{item.created_at}}</text>
					</view>
				</view>
				<view wx:if="{{item._partnerStatus === 'accepted'}}" class="feed-status-tag accepted">
					<van-icon name="checked" size="12px" color="#4CAF50" /><text>伙伴</text>
				</view>
				<view wx:elif="{{item._partnerStatus === 'pending'}}" class="feed-status-tag pending">
					<text>已邀请</text>
				</view>
				<view wx:elif="{{item._partnerStatus !== 'self'}}" class="feed-follow-btn" catchtap="quickAddFriend" data-uid="{{item.user_id}}" data-index="{{index}}">
					<van-icon name="plus" size="14px" color="#4A90D9" /><text>加伙伴</text>
				</view>
			</view>
			<view class="feed-body" bindtap="goDetail" data-id="{{item.id}}">
				<text class="feed-title">{{item.title}}</text>
				<text class="feed-text text-gray">{{item.content}}</text>
				<view class="feed-tags" wx:if="{{item.tags && item.tags.length > 0}}">
					<van-tag plain type="primary" size="medium" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" custom-class="feed-tag">{{tag}}</van-tag>
				</view>
			</view>
			<view class="feed-actions">
				<view class="feed-action" data-id="{{item.id}}" data-index="{{index}}" catchtap="toggleLike">
					<van-icon name="{{item.is_liked ? 'good-job' : 'good-job-o'}}" color="{{item.is_liked ? '#ff4757' : '#999'}}" size="18px" />
					<text class="action-num">{{item.like_cnt || 0}}</text>
				</view>
				<view class="feed-action" bindtap="goDetail" data-id="{{item.id}}">
					<van-icon name="chat-o" color="#999" size="18px" />
					<text class="action-num">{{item.comment_cnt || 0}}</text>
				</view>
				<view class="feed-action">
					<van-icon name="eye-o" color="#999" size="18px" />
					<text class="action-num">{{item.view_cnt || 0}}</text>
				</view>
			</view>
		</view>
	</view>

	<van-empty wx:if="{{!loading && notes.length === 0}}" description="暂无内容" />
	<van-divider wx:if="{{!hasMore && notes.length > 0}}" contentPosition="center">没有更多了</van-divider>
</view>
