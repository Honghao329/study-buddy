.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx 20rpx;
}
.stat-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}
.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
}
.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.admin-menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 10rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.admin-menu-item:last-child {
  border-bottom: none;
}
.menu-text {
  font-size: 30rpx;
  color: #333;
}
.menu-arrow {
  color: #ccc;
  font-size: 28rpx;
}
