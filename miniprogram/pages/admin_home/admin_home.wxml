<view class="container">
  <!-- Stats Grid -->
  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-num">{{stats.userCount}}</view>
      <view class="stat-label">用户总数</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{stats.noteCount}}</view>
      <view class="stat-label">笔记总数</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{stats.signCount}}</view>
      <view class="stat-label">签到总数</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{stats.checkinCount}}</view>
      <view class="stat-label">打卡活动</view>
    </view>
  </view>

  <!-- Menu -->
  <view class="card">
    <view class="admin-menu-item" bindtap="goUsers">
      <text class="menu-text">用户管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="admin-menu-item" bindtap="goNotes">
      <text class="menu-text">笔记管理</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="admin-menu-item" bindtap="goCheckins">
      <text class="menu-text">打卡管理</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="btn-danger mt20" bindtap="doLogout">退出管理</view>
</view>
