<view class="page-today">
	<!-- 自定义导航栏 -->
	<view class="nav-bar" style="padding-top:{{statusBarH}}px">
		<view class="nav-inner">
			<view class="nav-left" wx:if="{{isLogin}}">
				<image wx:if="{{avatar}}" class="nav-avatar" src="{{avatar}}" mode="aspectFill" bindtap="goMy" />
				<view wx:else class="nav-avatar-ph" bindtap="goMy"><van-icon name="smile-o" size="16px" color="#fff" /></view>
			</view>
			<text class="nav-title">学习伴侣</text>
			<view class="nav-right">
				<view class="nav-bell" bindtap="goMessages">
					<van-icon name="bell" size="20px" color="#333" />
					<view wx:if="{{unreadCount > 0}}" class="nav-dot"></view>
				</view>
			</view>
		</view>
	</view>

	<!-- 未登录 -->
	<view wx:if="{{!isLogin}}" class="login-card" bindtap="goLogin">
		<van-icon name="friends-o" size="40px" color="#4A90D9" />
		<view class="login-info">
			<text class="login-t">登录开启学习之旅</text>
			<text class="login-d">签到打卡、结交伙伴、共同成长</text>
		</view>
		<van-icon name="arrow" size="16px" color="#ccc" />
	</view>

	<!-- 已登录 -->
	<block wx:if="{{isLogin}}">
		<!-- 签到状态条 -->
		<view class="sign-bar {{signStats.todaySigned ? 'signed' : ''}}" bindtap="onMainCTA">
			<view class="sign-left">
				<text class="sign-fire">🔥</text>
				<text class="sign-streak">{{signStats.streak || 0}}天连续</text>
				<text class="sign-sep">·</text>
				<text class="sign-total">累计{{signStats.totalDays || 0}}天</text>
			</view>
			<view class="sign-btn-mini" wx:if="{{!signStats.todaySigned}}">签到</view>
			<text class="sign-done" wx:else>✓ 已签</text>
		</view>

		<!-- 内容 Tab -->
		<van-tabs active="{{activeTab}}" bind:change="onTabChange" color="#4A90D9" title-active-color="#4A90D9" line-width="40rpx" animated swipeable>
			<!-- Tab 1: 待办 -->
			<van-tab title="待办">
				<view class="tab-body">
					<view wx:if="{{todayTasks.length > 0}}">
						<view class="task-head">
							<text class="task-head-t">今日打卡任务</text>
							<text class="task-head-p">{{todayDone}}/{{todayTasks.length}}</text>
						</view>
						<view class="task-card" wx:for="{{todayTasks}}" wx:key="id" data-id="{{item.id}}" bindtap="goCheckin">
							<view class="task-ck {{item._joined ? 'ck-done' : ''}}">
								<van-icon wx:if="{{item._joined}}" name="success" size="11px" color="#fff" />
							</view>
							<view class="task-info">
								<text class="task-name {{item._joined ? 'name-done' : ''}}">{{item.title}}</text>
								<text class="task-sub">{{item.join_cnt || 0}}人参与</text>
							</view>
							<van-icon name="arrow" size="14px" color="#ddd" />
						</view>
					</view>
					<view wx:else class="empty-tab">
						<van-empty description="暂无打卡任务" image="search" />
						<van-button size="small" round type="primary" bindtap="goCheckinList" custom-style="margin-top:16rpx">去看看</van-button>
					</view>
				</view>
			</van-tab>

			<!-- Tab 2: 发现 -->
			<van-tab title="发现">
				<view class="tab-body">
					<view wx:if="{{notes.length > 0}}">
						<view class="note-card" wx:for="{{notes}}" wx:key="id" data-id="{{item.id}}" bindtap="goNote">
							<view class="note-top">
								<image class="note-av" src="{{item.user_pic}}" mode="aspectFill" />
								<text class="note-author">{{item.user_name || '匿名'}}</text>
							</view>
							<text class="note-title">{{item.title}}</text>
							<text class="note-desc" wx:if="{{item.content}}">{{item.content}}</text>
							<view class="note-stats">
								<text class="note-stat"><van-icon name="good-job-o" size="14px" color="#ccc" /> {{item.like_cnt || 0}}</text>
								<text class="note-stat"><van-icon name="eye-o" size="14px" color="#ccc" /> {{item.view_cnt || 0}}</text>
								<text class="note-stat"><van-icon name="chat-o" size="14px" color="#ccc" /> {{item.comment_cnt || 0}}</text>
							</view>
						</view>
					</view>
					<van-empty wx:else description="暂无热门笔记" image="search" />
				</view>
			</van-tab>

			<!-- Tab 3: 动态 -->
			<van-tab title="动态">
				<view class="tab-body">
					<view wx:if="{{activities.length > 0}}">
						<view class="act-card" wx:for="{{activities}}" wx:key="index">
							<image wx:if="{{item.avatar}}" class="act-av" src="{{item.avatar}}" mode="aspectFill" />
							<view wx:else class="act-dot" style="background:{{item.color}}"><van-icon name="{{item.icon}}" size="10px" color="#fff" /></view>
							<view class="act-info">
								<text class="act-text">{{item.text}}</text>
								<text class="act-time">{{item.time}}</text>
							</view>
						</view>
					</view>
					<van-empty wx:else description="暂无动态" image="search" />
				</view>
			</van-tab>
		</van-tabs>
	</block>

	<!-- 签到弹窗 -->
	<van-popup show="{{showSign}}" position="bottom" round bind:close="closeSign" safe-area-inset-bottom>
		<view class="popup">
			<view class="popup-hd">记录今天的学习</view>
			<view class="field">
				<text class="field-label">学习时长（分钟）</text>
				<input class="field-input" type="number" placeholder="选填" value="{{signDuration}}" bindinput="onSignDuration" />
			</view>
			<view class="field">
				<text class="field-label">学习状态</text>
				<view class="mood-row">
					<view class="mood {{signStatus==0?'mood-on':''}}" bindtap="setSignStatus" data-idx="0">😊 高效</view>
					<view class="mood {{signStatus==1?'mood-on':''}}" bindtap="setSignStatus" data-idx="1">😐 一般</view>
					<view class="mood {{signStatus==2?'mood-on':''}}" bindtap="setSignStatus" data-idx="2">😴 疲惫</view>
				</view>
			</view>
			<view class="field">
				<text class="field-label">学习内容</text>
				<textarea class="field-area" placeholder="选填" value="{{signContent}}" bindinput="onSignContent" maxlength="200" auto-height />
			</view>
			<van-button type="primary" block round bind:click="doSign" loading="{{signing}}" custom-style="margin-top:24rpx">确认</van-button>
		</view>
	</van-popup>
</view>
