<view class="page-index">
	<!-- 公告栏 -->
	<van-notice-bar left-icon="volume-o" text="欢迎使用学习伴侣系统，记录学习、结交伙伴、每天进步一点点！" scrollable wrapable="{{false}}" color="#4A90D9" background="#EBF3FC" />

	<!-- 快捷导航 - 4个入口 -->
	<view class="nav-grid card">
		<view class="nav-item" bindtap="goSign">
			<view class="nav-icon" style="background:#FFF3E0;">
				<van-icon name="clock-o" color="#FF9800" size="24px" />
			</view>
			<text class="nav-text">签到</text>
		</view>
		<view class="nav-item" bindtap="goPartner">
			<view class="nav-icon" style="background:#E8F5E9;">
				<van-icon name="friends-o" color="#4CAF50" size="24px" />
			</view>
			<text class="nav-text">伙伴</text>
		</view>
		<view class="nav-item" bindtap="goCheckinList">
			<view class="nav-icon" style="background:#E3F2FD;">
				<van-icon name="todo-list-o" color="#2196F3" size="24px" />
			</view>
			<text class="nav-text">打卡</text>
		</view>
		<view class="nav-item" bindtap="goCommunity">
			<view class="nav-icon" style="background:#FCE4EC;">
				<van-icon name="comment-o" color="#E91E63" size="24px" />
			</view>
			<text class="nav-text">社区</text>
		</view>
	</view>

	<!-- 打卡任务（横向滚动） -->
	<view class="section">
		<view class="section-header">
			<text class="section-title">打卡任务</text>
			<text class="section-more" bindtap="goCheckinList">查看全部 <van-icon name="arrow" size="12px" /></text>
		</view>
		<scroll-view scroll-x class="checkin-scroll" wx:if="{{checkins.length > 0}}">
			<view class="checkin-card" wx:for="{{checkins}}" wx:key="id" data-id="{{item.id}}" bindtap="goCheckin">
				<view class="checkin-title">{{item.title}}</view>
				<view class="checkin-count">
					<van-icon name="friends-o" size="12px" color="#fff" />
					<text>{{item.join_cnt || 0}}人</text>
				</view>
			</view>
		</scroll-view>
		<van-empty wx:if="{{checkins.length === 0}}" description="暂无打卡任务" image="search" />
	</view>

	<!-- 热门笔记 -->
	<view class="section">
		<view class="section-header">
			<text class="section-title">热门笔记</text>
			<text class="section-more" bindtap="goCommunity">查看全部 <van-icon name="arrow" size="12px" /></text>
		</view>
		<view class="note-item card" wx:for="{{notes}}" wx:key="id" data-id="{{item.id}}" bindtap="goNote">
			<view class="note-top">
				<view class="note-title">{{item.title}}</view>
			</view>
			<view class="note-preview" wx:if="{{item.content}}">{{item.content}}</view>
			<view class="note-bottom">
				<view class="note-author-row">
					<view class="avatar-dot"></view>
					<text class="note-author-name">{{item.user_name || '匿名'}}</text>
				</view>
				<view class="note-stats">
					<view class="note-stat-item">
						<van-icon name="good-job-o" size="14px" color="#999" />
						<text>{{item.like_cnt || 0}}</text>
					</view>
					<view class="note-stat-item">
						<van-icon name="chat-o" size="14px" color="#999" />
						<text>{{item.comment_cnt || 0}}</text>
					</view>
					<view class="note-stat-item">
						<van-icon name="eye-o" size="14px" color="#999" />
						<text>{{item.view_cnt || 0}}</text>
					</view>
				</view>
			</view>
		</view>
		<van-empty wx:if="{{notes.length === 0}}" description="暂无笔记" image="search" />
	</view>
</view>
