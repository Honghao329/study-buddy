.page-index { padding-bottom: 20rpx; }

/* 顶部栏 */
.top-bar { display: flex; align-items: center; gap: 16rpx; padding: 10rpx 20rpx 0; }
.msg-entry { position: relative; padding: 10rpx; }
.msg-badge {
  position: absolute; top: 2rpx; right: 0;
  background: #f56c6c; color: #fff; font-size: 18rpx;
  min-width: 28rpx; height: 28rpx; line-height: 28rpx;
  text-align: center; border-radius: 14rpx; padding: 0 6rpx;
}

/* 引导卡片 */
.guide-card { margin: 16rpx 20rpx 0; display: flex; align-items: center; gap: 20rpx; padding: 28rpx; }
.guide-text { flex: 1; }
.guide-title { font-size: 30rpx; font-weight: bold; color: #333; }
.guide-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; }

/* 快捷导航 */
.nav-grid { margin: 16rpx 20rpx 0; display: flex; justify-content: space-around; padding: 24rpx 10rpx; }
.nav-item { display: flex; flex-direction: column; align-items: center; }
.nav-icon { width: 88rpx; height: 88rpx; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 10rpx; }
.nav-text { font-size: 24rpx; color: #555; font-weight: 500; }

/* Section */
.section { margin-top: 24rpx; padding: 0 20rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; }
.section-more { font-size: 24rpx; color: #4A90D9; }

/* 最新动态 */
.activity-list { background: #fff; border-radius: 16rpx; padding: 8rpx 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03); }
.activity-item { display: flex; align-items: center; gap: 14rpx; padding: 16rpx 0; border-bottom: 1rpx solid #f8f8f8; }
.activity-item:last-child { border-bottom: none; }
.activity-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; flex-shrink: 0; }
.activity-dot { width: 36rpx; height: 36rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.activity-text { flex: 1; font-size: 24rpx; color: #555; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.activity-time { font-size: 20rpx; color: #ccc; flex-shrink: 0; }

/* 打卡横向滚动 */
.checkin-scroll { white-space: nowrap; padding-bottom: 10rpx; }
.checkin-card { display: inline-block; width: 240rpx; padding: 24rpx; margin-right: 16rpx; background: linear-gradient(135deg, #4A90D9, #667eea); border-radius: 18rpx; color: #fff; vertical-align: top; }
.checkin-title { font-size: 28rpx; font-weight: 600; margin-bottom: 14rpx; white-space: normal; line-height: 1.4; }
.checkin-count { font-size: 22rpx; opacity: 0.85; display: flex; align-items: center; gap: 6rpx; }

/* 笔记卡片 */
.note-item { margin-bottom: 16rpx; padding: 24rpx; }
.note-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 10rpx; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.note-preview { font-size: 26rpx; color: #888; line-height: 1.6; margin-bottom: 14rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.note-bottom { display: flex; justify-content: space-between; align-items: center; }
.note-author-row { display: flex; align-items: center; gap: 8rpx; }
.note-author-avatar { width: 28rpx; height: 28rpx; border-radius: 50%; }
.avatar-dot { width: 24rpx; height: 24rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); }
.note-author-name { font-size: 24rpx; color: #666; }
.note-stats { display: flex; gap: 20rpx; }
.note-stat-item { display: flex; align-items: center; gap: 4rpx; font-size: 22rpx; color: #999; }
