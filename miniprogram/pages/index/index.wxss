.page-index { padding-bottom: 20rpx; }

/* Hero */
.hero {
  margin: 20rpx 20rpx 0;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #6BB5F0 60%, #89C4F4 100%);
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
}
.hero-title { font-size: 40rpx; font-weight: bold; }
.hero-desc { font-size: 26rpx; opacity: 0.85; margin-top: 8rpx; }
.hero-date { font-size: 28rpx; opacity: 0.9; background: rgba(255,255,255,0.2); padding: 10rpx 24rpx; border-radius: 30rpx; }

/* 快捷导航 */
.nav-grid {
  margin: 20rpx 20rpx 0;
  display: flex;
  justify-content: space-around;
  padding: 28rpx 10rpx;
}
.nav-item { display: flex; flex-direction: column; align-items: center; }
.nav-icon {
  width: 96rpx; height: 96rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
}
.nav-text { font-size: 24rpx; color: #555; font-weight: 500; }

/* Section */
.section { margin-top: 24rpx; padding: 0 20rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: #333; }
.section-more { font-size: 24rpx; color: #4A90D9; }

/* 打卡横向滚动 */
.checkin-scroll { white-space: nowrap; padding-bottom: 10rpx; }
.checkin-card {
  display: inline-block;
  width: 260rpx;
  padding: 28rpx;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #4A90D9, #667eea);
  border-radius: 20rpx;
  color: #fff;
  vertical-align: top;
}
.checkin-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; white-space: normal; line-height: 1.4; }
.checkin-count { font-size: 22rpx; opacity: 0.85; display: flex; align-items: center; gap: 6rpx; }

/* 笔记卡片 */
.note-item { margin-bottom: 16rpx; padding: 28rpx; }
.note-top { margin-bottom: 12rpx; }
.note-title { font-size: 30rpx; font-weight: bold; color: #333; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.note-preview { font-size: 26rpx; color: #888; line-height: 1.6; margin-bottom: 16rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.note-bottom { display: flex; justify-content: space-between; align-items: center; }
.note-author-row { display: flex; align-items: center; gap: 10rpx; }
.avatar-dot { width: 24rpx; height: 24rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); }
.note-author-name { font-size: 24rpx; color: #666; }
.note-stats { display: flex; gap: 20rpx; }
.note-stat-item { display: flex; align-items: center; gap: 6rpx; font-size: 22rpx; color: #999; }
