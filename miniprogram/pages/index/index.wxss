.page-today { background: #f5f6fa; min-height: 100vh; }

/* ===== 自定义导航栏 ===== */
.nav-bar { background: #fff; position: sticky; top: 0; z-index: 100; }
.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
  height: 88rpx; padding: 0 24rpx;
}
.nav-left { margin-right: 12rpx; }
.nav-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; border: 2rpx solid #f0f0f0; }
.nav-avatar-ph {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #4A90D9; display: flex; align-items: center; justify-content: center;
}
.nav-title { flex: 1; font-size: 32rpx; font-weight: 700; color: #222; }
.nav-right { display: flex; align-items: center; }
.nav-bell { position: relative; padding: 8rpx; }
.nav-dot {
  position: absolute; top: 6rpx; right: 4rpx;
  width: 14rpx; height: 14rpx; background: #f44336; border-radius: 50%; border: 2rpx solid #fff;
}

/* ===== 未登录 ===== */
.login-card {
  display: flex; align-items: center; gap: 20rpx;
  margin: 16rpx 24rpx; padding: 28rpx; background: #fff;
  border-radius: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.login-info { flex: 1; }
.login-t { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.login-d { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

/* ===== 签到状态条 ===== */
.sign-bar {
  display: flex; align-items: center; justify-content: space-between;
  margin: 12rpx 24rpx; padding: 18rpx 24rpx;
  background: #fff; border-radius: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #FF9800;
}
.sign-bar.signed { border-left-color: #4CAF50; }
.sign-left { display: flex; align-items: center; gap: 6rpx; }
.sign-fire { font-size: 22rpx; }
.sign-streak { font-size: 26rpx; font-weight: 700; color: #FF9800; }
.sign-bar.signed .sign-streak { color: #4CAF50; }
.sign-sep { color: #eee; font-size: 20rpx; }
.sign-total { font-size: 22rpx; color: #bbb; }
.sign-btn-mini {
  font-size: 24rpx; font-weight: 600; color: #fff;
  background: #4A90D9; padding: 8rpx 28rpx; border-radius: 24rpx;
}
.sign-btn-mini:active { opacity: 0.85; }
.sign-done { font-size: 24rpx; color: #4CAF50; font-weight: 500; }

/* ===== Tab 内容 ===== */
.tab-body { padding: 16rpx 24rpx 24rpx; min-height: 400rpx; }
.empty-tab { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; }

/* ===== 待办 Tab ===== */
.task-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.task-head-t { font-size: 26rpx; font-weight: 600; color: #333; }
.task-head-p { font-size: 22rpx; color: #4A90D9; font-weight: 500; }

.task-card {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: 14rpx; padding: 22rpx 24rpx;
  margin-bottom: 10rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.task-card:active { background: #fafbfc; }
.task-ck {
  width: 30rpx; height: 30rpx; border-radius: 50%; flex-shrink: 0;
  border: 2rpx solid #ddd;
  display: flex; align-items: center; justify-content: center;
}
.task-ck.ck-done { background: #4CAF50; border-color: #4CAF50; }
.task-info { flex: 1; min-width: 0; }
.task-name { font-size: 28rpx; color: #333; font-weight: 500; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.task-name.name-done { color: #ccc; text-decoration: line-through; }
.task-sub { font-size: 22rpx; color: #bbb; display: block; margin-top: 2rpx; }

/* ===== 发现 Tab ===== */
.note-card {
  background: #fff; border-radius: 14rpx; padding: 22rpx 24rpx;
  margin-bottom: 12rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.note-card:active { background: #fafbfc; }
.note-top { display: flex; align-items: center; gap: 10rpx; margin-bottom: 10rpx; }
.note-av { width: 36rpx; height: 36rpx; border-radius: 50%; flex-shrink: 0; }
.note-author { font-size: 24rpx; color: #999; }
.note-title {
  font-size: 28rpx; font-weight: 600; color: #333; display: block;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5;
}
.note-desc {
  font-size: 24rpx; color: #aaa; margin-top: 8rpx; display: block; line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
.note-stats { display: flex; gap: 24rpx; margin-top: 12rpx; }
.note-stat { display: flex; align-items: center; gap: 4rpx; font-size: 22rpx; color: #ccc; }

/* ===== 动态 Tab ===== */
.act-card {
  display: flex; align-items: flex-start; gap: 14rpx;
  background: #fff; border-radius: 14rpx; padding: 18rpx 22rpx;
  margin-bottom: 10rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.act-av { width: 36rpx; height: 36rpx; border-radius: 50%; flex-shrink: 0; margin-top: 2rpx; }
.act-dot {
  width: 36rpx; height: 36rpx; border-radius: 50%; flex-shrink: 0; margin-top: 2rpx;
  display: flex; align-items: center; justify-content: center;
}
.act-info { flex: 1; min-width: 0; }
.act-text { font-size: 26rpx; color: #555; display: block; line-height: 1.5; }
.act-time { font-size: 20rpx; color: #ccc; display: block; margin-top: 4rpx; }

/* ===== 弹窗 ===== */
.popup { padding: 36rpx; }
.popup-hd { font-size: 32rpx; font-weight: 700; text-align: center; margin-bottom: 28rpx; }
.field { margin-bottom: 22rpx; }
.field-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; display: block; font-weight: 500; }
.field-input {
  border: 2rpx solid #eee; border-radius: 12rpx; padding: 18rpx 20rpx;
  font-size: 28rpx; background: #fafbfc; width: 100%; box-sizing: border-box;
  min-height: 68rpx; line-height: 1.5;
}
.field-area {
  border: 2rpx solid #eee; border-radius: 12rpx; padding: 18rpx 20rpx;
  font-size: 28rpx; background: #fafbfc; width: 100%; box-sizing: border-box;
  min-height: 100rpx; line-height: 1.5;
}
.mood-row { display: flex; gap: 12rpx; }
.mood {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 12rpx;
  font-size: 26rpx; color: #666; background: #f5f6fa; line-height: 1.5;
}
.mood.mood-on { background: #EBF3FC; color: #4A90D9; font-weight: 600; }
