<view class="container">
  <!-- 头像 -->
  <view class="card avatar-card" bindtap="onPickAvatar">
    <view class="avatar-row">
      <text class="form-label-inline">头像</text>
      <view class="avatar-right">
        <image wx:if="{{avatarUrl}}" class="edit-avatar" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="edit-avatar-default"><van-icon name="photograph" size="24px" color="#4A90D9" /></view>
        <van-icon name="arrow" color="#ccc" size="16px" />
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="form-group">
      <view class="form-label">昵称 <text class="form-hint">（也是登录账号，修改后用新昵称登录）</text></view>
      <input class="input" placeholder="请输入昵称" value="{{nickName}}" bindinput="onNickNameInput" maxlength="20" />
    </view>

    <view class="form-group">
      <view class="form-label">个人简介</view>
      <textarea class="input textarea" placeholder="介绍一下自己吧" value="{{bio}}" bindinput="onBioInput" maxlength="200" auto-height></textarea>
    </view>

    <view class="form-group">
      <view class="form-label">手机号</view>
      <input class="input" placeholder="请输入手机号" value="{{mobile}}" bindinput="onMobileInput" type="number" maxlength="11" />
    </view>

    <view class="form-group">
      <view class="form-label">兴趣标签 <text class="form-hint">（逗号分隔，最多5个）</text></view>
      <input class="input" placeholder="如：考研,英语,编程" value="{{tagsStr}}" bindinput="onTagsInput" maxlength="50" />
    </view>
  </view>

  <view class="btn-primary mt20" bindtap="doSave">保存资料</view>

  <!-- 修改密码 -->
  <view class="card mt20">
    <view class="section-label">修改密码</view>
    <view class="form-group">
      <view class="form-label">旧密码</view>
      <input class="input" type="text" password placeholder="输入当前密码" value="{{oldPassword}}" bindinput="onOldPwdInput" maxlength="20" />
    </view>
    <view class="form-group">
      <view class="form-label">新密码</view>
      <input class="input" type="text" password placeholder="输入新密码（至少4位）" value="{{newPassword}}" bindinput="onNewPwdInput" maxlength="20" />
    </view>
    <view class="btn-outline" bindtap="doChangePwd">修改密码</view>
  </view>
</view>
