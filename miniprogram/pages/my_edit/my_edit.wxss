.avatar-card { padding: 24rpx 30rpx; }
.avatar-row { display: flex; align-items: center; justify-content: space-between; }
.avatar-right { display: flex; align-items: center; gap: 12rpx; }
.edit-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; }
.edit-avatar-default {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #f0f4ff; display: flex; align-items: center; justify-content: center;
}
.form-label-inline { font-size: 28rpx; color: #333; font-weight: 500; }
.form-group { margin-bottom: 28rpx; }
.form-group:last-child { margin-bottom: 0; }
.form-label { font-size: 28rpx; color: #666; margin-bottom: 10rpx; font-weight: 500; }
.form-hint { font-size: 22rpx; color: #bbb; font-weight: normal; }
.form-hint-block { font-size: 22rpx; color: #bbb; margin-top: 8rpx; }
.input.disabled { background: #f0f0f0; color: #999; }
.textarea { min-height: 140rpx; width: 100%; box-sizing: border-box; }
.section-label { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 20rpx; }
