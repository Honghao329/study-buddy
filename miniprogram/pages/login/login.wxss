.login-page {
	min-height: 100vh;
	background: linear-gradient(180deg, #4A90D9 0%, #6BB5F0 35%, #f5f6fa 35%);
	padding-bottom: 60rpx;
}

/* 顶部装饰圆 */
.login-top { position: relative; height: 0; }
.login-circle { position: absolute; border-radius: 50%; opacity: 0.1; background: #fff; }
.c1 { width: 200rpx; height: 200rpx; top: -60rpx; right: -40rpx; }
.c2 { width: 120rpx; height: 120rpx; top: 40rpx; left: 30rpx; }
.c3 { width: 80rpx; height: 80rpx; top: 20rpx; right: 120rpx; }

/* Logo区域 */
.login-logo {
	padding: 80rpx 0 40rpx;
	text-align: center;
}
.logo-icon {
	width: 120rpx; height: 120rpx; border-radius: 30rpx;
	background: rgba(255,255,255,0.2);
	display: flex; align-items: center; justify-content: center;
	margin: 0 auto 20rpx;
	backdrop-filter: blur(10px);
}
.logo-title {
	font-size: 40rpx; font-weight: bold; color: #fff;
	letter-spacing: 4rpx; margin-bottom: 8rpx;
}
.logo-desc {
	font-size: 24rpx; color: rgba(255,255,255,0.85);
}

/* 登录表单卡片 */
.login-form {
	margin: 0 40rpx;
	background: #fff;
	border-radius: 24rpx;
	padding: 40rpx 36rpx;
	box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.08);
}

/* 头像选择 */
.avatar-section {
	text-align: center;
	margin-bottom: 30rpx;
}
.avatar-wrap {
	width: 130rpx; height: 130rpx; border-radius: 50%;
	margin: 0 auto 12rpx;
	overflow: hidden;
	border: 4rpx solid #EBF3FC;
}
.avatar-img {
	width: 100%; height: 100%;
}
.avatar-placeholder {
	width: 100%; height: 100%;
	background: #f0f4ff;
	display: flex; align-items: center; justify-content: center;
}
.avatar-tip {
	font-size: 22rpx; color: #999;
}

/* 输入框 */
.input-group {
	margin-bottom: 20rpx;
	position: relative;
}
.input-label {
	display: flex; align-items: center; gap: 8rpx;
	font-size: 26rpx; color: #666; margin-bottom: 10rpx; font-weight: 500;
}
.login-input {
	width: 100%; box-sizing: border-box;
	border: 2rpx solid #e8eef6; border-radius: 16rpx;
	padding: 0 24rpx; font-size: 30rpx; background: #f8fbff;
	height: 88rpx; min-height: 88rpx;
}
.pwd-toggle {
	position: absolute;
	right: 20rpx; bottom: 24rpx;
	padding: 8rpx;
}

/* 提示 */
.login-hint {
	text-align: center; margin-top: 20rpx;
	font-size: 22rpx; color: #bbb;
}
